<script>
(function () {
  var STORAGE_KEY = 'ds_wheel_dismissed';
  if (localStorage.getItem(STORAGE_KEY)) return;

  var overlay    = document.getElementById('emailPopupOverlay');
  var closeBtn   = document.getElementById('emailPopupClose');
  var form       = document.getElementById('emailPopupForm');
  var formSec    = document.getElementById('epopFormSection');
  var loseOverlay = document.getElementById('epopLoseOverlay');
  var winOverlay  = document.getElementById('epopWinOverlay');
  var copyBtn     = document.getElementById('epopCopyBtn');
  var errorEl    = document.getElementById('epopError');
  var submitBtn  = document.getElementById('epopSubmitBtn');
  var spinEl     = document.getElementById('epopWheelSpin');
  var canvas     = document.getElementById('epopWheelCanvas');

  if (!overlay || !canvas) return;

  // ├втАЭтВм├втАЭтВм├втАЭтВм Segmentos ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  // weight 0 = nunca se selecciona (aparece visualmente pero no puede salir)
  var SEGS = [
    { lines: ['12%', 'OFF'],   bg: '#1e3a5f', fg: '#ffffff', weight: 0,  type: 'discount' },
    { lines: ['PERDISTE'],     bg: '#7f1d1d', fg: '#fca5a5', weight: 27, type: 'lose'     },
    { lines: ['20%', 'OFF'],   bg: '#1e3a5f', fg: '#ffffff', weight: 0,  type: 'discount' },
    { lines: ['PERDISTE'],     bg: '#7f1d1d', fg: '#fca5a5', weight: 27, type: 'lose'     },
    { lines: ['3%', 'OFF \u2605'], bg: '#fbbf24', fg: '#000000', weight: 50, type: 'win', code: 'DREAM2026' },
    { lines: ['10%', 'OFF'],   bg: '#1e3a5f', fg: '#ffffff', weight: 0,  type: 'discount' },
    { lines: ['PERDISTE'],     bg: '#7f1d1d', fg: '#fca5a5', weight: 26, type: 'lose'     },
    { lines: ['5%', 'OFF'],    bg: '#1e3a5f', fg: '#ffffff', weight: 0,  type: 'discount' }
  ];

  // ├втАЭтВм├втАЭтВм├втАЭтВм Dibujar ruleta ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  function drawWheel() {
    var ctx = canvas.getContext('2d');
    var n   = SEGS.length;
    var cx  = canvas.width  / 2;
    var cy  = canvas.height / 2;
    var r   = Math.min(cx, cy) - 2;
    var arc = (2 * Math.PI) / n;
    var off = -Math.PI / 2; // empezar desde arriba

    for (var i = 0; i < n; i++) {
      var s     = SEGS[i];
      var start = off + i * arc;
      var end   = start + arc;

      // Sector
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, start, end);
      ctx.closePath();
      ctx.fillStyle = s.bg;
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,0.07)';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Texto
      var mid = start + arc / 2;
      var tr  = r * 0.62;
      var tx  = cx + Math.cos(mid) * tr;
      var ty  = cy + Math.sin(mid) * tr;

      ctx.save();
      ctx.translate(tx, ty);
      ctx.rotate(mid + Math.PI / 2);
      ctx.fillStyle = s.fg;
      ctx.font = 'bold 10px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      s.lines.forEach(function (line, li) {
        ctx.fillText(line, 0, (li - (s.lines.length - 1) / 2) * 13);
      });
      ctx.restore();
    }

    // Centro
    ctx.beginPath();
    ctx.arc(cx, cy, 14, 0, 2 * Math.PI);
    ctx.fillStyle = '#0d0d0d';
    ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  drawWheel();

  // ├втАЭтВм├втАЭтВм├втАЭтВм Selecci├Г┬│n aleatoria ponderada ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  function pickSegment() {
    var total = SEGS.reduce(function (s, seg) { return s + seg.weight; }, 0);
    var rand  = Math.random() * total;
    for (var i = 0; i < SEGS.length; i++) {
      rand -= SEGS[i].weight;
      if (rand <= 0) return i;
    }
    return SEGS.length - 1;
  }

  // ├втАЭтВм├втАЭтВм├втАЭтВм Animaci├Г┬│n de giro ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  var totalRot = 0;
  var spinning = false;

  function spinTo(segIdx, onDone) {
    var n      = SEGS.length;
    var arcDeg = 360 / n;
    // Centro del segmento objetivo en grados desde arriba (sentido horario)
    var center = segIdx * arcDeg + arcDeg / 2;
    // Variaci├Г┬│n aleatoria dentro del segmento (├В┬▒40% del arco)
    var jitter = (Math.random() - 0.5) * arcDeg * 0.8;
    // Rotaci├Г┬│n clockwise necesaria para llevar ese punto al puntero (arriba)
    var target  = ((360 - center + jitter) % 360 + 360) % 360;
    var curNorm = ((totalRot % 360) + 360) % 360;
    var delta   = (target - curNorm + 360) % 360;
    if (delta < 45) delta += 360;

    var newRot = totalRot + 360 * 6 + delta;
    totalRot   = newRot;

    spinEl.style.transform = 'rotate(' + newRot + 'deg)';

    spinEl.addEventListener('transitionend', function handler() {
      spinEl.removeEventListener('transitionend', handler);
      spinning = false;
      if (onDone) onDone();
    });
  }

  // ├втАЭтВм├втАЭтВм├втАЭтВм Abrir / cerrar popup ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  function openPopup() {
    overlay.removeAttribute('aria-hidden');
    overlay.classList.add('epop-visible');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    overlay.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('epop-visible');
    document.body.style.overflow = '';
    localStorage.setItem(STORAGE_KEY, '1');
  }

  setTimeout(openPopup, 4000);

  closeBtn.addEventListener('click', closePopup);
  overlay.addEventListener('click', function (e) { if (e.target === overlay) closePopup(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') { closePopup(); closeResultPopups(); } });

  function closeResultPopups() {
    [loseOverlay, winOverlay].forEach(function (el) {
      if (!el) return;
      el.setAttribute('aria-hidden', 'true');
      el.classList.remove('epop-result-visible');
    });
    document.body.style.overflow = '';
  }

  function openResultPopup(el) {
    if (!el) return;
    el.removeAttribute('aria-hidden');
    el.classList.add('epop-result-visible');
    document.body.style.overflow = 'hidden';
  }

  ['epopLoseClose', 'epopLoseDismiss', 'epopWinClose'].forEach(function (id) {
    var btn = document.getElementById(id);
    if (btn) btn.addEventListener('click', closeResultPopups);
  });

  var winDismiss = document.getElementById('epopWinDismiss');
  if (winDismiss) winDismiss.addEventListener('click', closeResultPopups);

  [loseOverlay, winOverlay].forEach(function (el) {
    if (el) el.addEventListener('click', function (e) { if (e.target === el) closeResultPopups(); });
  });

  // ├втАЭтВм├втАЭтВм├втАЭтВм Env├Г┬нo del formulario ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (spinning) return;

    var emailVal = document.getElementById('epopEmail').value.trim();
    if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      errorEl.hidden = false;
      document.getElementById('epopEmail').focus();
      return;
    }
    errorEl.hidden = true;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Girando\u2026';
    spinning = true;

    // Enviar datos a Shopify en segundo plano
    var data = new FormData(form);
    fetch('/contact', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: data
    }).catch(function () {});

    // Girar con resultado predeterminado (ponderado)
    var segIdx = pickSegment();
    spinTo(segIdx, function () {
      var seg = SEGS[segIdx];
      localStorage.setItem(STORAGE_KEY, '1');
      closePopup();
      if (seg.type === 'win') {
        openResultPopup(winOverlay);
      } else {
        openResultPopup(loseOverlay);
      }
    });
  });

  // ├втАЭтВм├втАЭтВм├втАЭтВм Copiar c├Г┬│digo ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var code = (document.getElementById('epopWinCode') || {}).textContent || '';
      if (navigator.clipboard) {
        navigator.clipboard.writeText(code).then(function () {
          copyBtn.textContent = '\u00a1Copiado!';
          setTimeout(function () { copyBtn.textContent = 'Copiar'; }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = code;
        ta.style.cssText = 'position:fixed;opacity:0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyBtn.textContent = '\u00a1Copiado!';
        setTimeout(function () { copyBtn.textContent = 'Copiar'; }, 2000);
      }
    });
  }

})();
</script>
