<div class="epop-overlay" id="emailPopupOverlay" aria-hidden="true">
  <div class="epop-modal" role="dialog" aria-modal="true" aria-labelledby="epopTitle">
    <button class="epop-close" id="emailPopupClose" aria-label="Cerrar">&#10005;</button>

    <p class="epop-tagline" id="epopTitle">¿Quieres conseguir un descuento<br>con nuestra ruleta?</p>
    <p class="epop-sub">Ingresa tus datos para activarla</p>

    <!-- Ruleta -->
    <div class="epop-wheel-section">
      <div class="epop-pointer">&#9660;</div>
      <div class="epop-wheel-outer">
        <div class="epop-wheel-spin" id="epopWheelSpin">
          <canvas id="epopWheelCanvas" width="240" height="240"></canvas>
        </div>
      </div>
    </div>

    <!-- Formulario -->
    <div id="epopFormSection">
      <form class="epop-form" id="emailPopupForm" method="post" action="/contact#contact_form" novalidate>
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="&#x2713;">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="hidden" name="customer[accepts_marketing]" value="true">

        <input
          class="epop-input"
          type="email"
          name="contact[email]"
          id="epopEmail"
          placeholder="Correo electrónico"
          required
          autocomplete="email"
        >
        <input
          class="epop-input"
          type="tel"
          name="contact[phone]"
          id="epopPhone"
          placeholder="Número de teléfono"
          autocomplete="tel"
        >
        <p class="epop-error" id="epopError" hidden>Ingresa un correo electrónico válido.</p>
        <button class="epop-btn" type="submit" id="epopSubmitBtn">¡Girar la ruleta!</button>
      </form>
    </div>

    <!-- Resultado (oculto hasta que termina el giro) -->
    <div class="epop-result" id="epopResult" hidden>
      <p class="epop-result-msg" id="epopResultMsg"></p>
      <div class="epop-code-wrap" id="epopCodeWrap" hidden>
        <p class="epop-code-label">Tu código de descuento:</p>
        <div class="epop-code-row">
          <strong class="epop-code" id="epopCode"></strong>
          <button class="epop-copy-btn" id="epopCopyBtn" type="button">Copiar</button>
        </div>
      </div>
      <button class="epop-dismiss-btn" id="epopDismiss" type="button">Cerrar</button>
    </div>

  </div>
</div>

