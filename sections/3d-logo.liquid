      "label": "Enlace 2 — URL"
    },
    {
      "type": "text",
      "id": "link_3_label",
      "label": "Enlace 3 — texto",
      "default": "Acuerdos"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Enlace 3 — URL"
    },
    {
      "type": "header",
      "content": "Submenú — Marcas"
    },
    {
      "type": "url",
      "id": "sub_marca_1_url",
      "label": "Polo Ralph Lauren — URL"
    },
    {
      "type": "url",
      "id": "sub_marca_2_url",
      "label": "Dream Smooth — URL"
    },
    {
      "type": "url",
      "id": "sub_marca_3_url",
      "label": "Otros — URL"
    },
    {
      "type": "header",
      "content": "Submenú — Estado"
    },
    {
      "type": "url",
      "id": "sub_estado_1_url",
