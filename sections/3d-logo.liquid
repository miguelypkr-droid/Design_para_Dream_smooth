<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

<!-- Caja 1: Logo 3D -->
<div style="width:100%; background:#000000; display:flex; justify-content:center; align-items:center; padding:1.5rem 0; box-sizing:border-box;">
  <model-viewer
    src="https://cdn.shopify.com/3d/models/o/d49653b2167972d2/Dreamsmoothlogo.glb"
    auto-rotate
    rotation-per-second="-30deg"
    camera-controls
    disable-zoom
    interaction-prompt="none"
    style="width:140px; height:140px; background:transparent; display:block;"
  ></model-viewer>
</div>

<!-- Caja 2: Barra de navegación -->
<div style="width:100%; background:{{ section.settings.nav_bg }}; display:flex; justify-content:center; align-items:center; gap:3rem; padding:0.9rem 2rem; box-sizing:border-box;">
  <a href="{{ section.settings.link_1_url }}" style="color:{{ section.settings.nav_color }}; text-decoration:none; font-size:0.85rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase;">{{ section.settings.link_1_label }}</a>
  <a href="{{ section.settings.link_2_url }}" style="color:{{ section.settings.nav_color }}; text-decoration:none; font-size:0.85rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase;">{{ section.settings.link_2_label }}</a>
  <a href="{{ section.settings.link_3_url }}" style="color:{{ section.settings.nav_color }}; text-decoration:none; font-size:0.85rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase;">{{ section.settings.link_3_label }}</a>
</div>

{% schema %}
{
  "name": "3D Logo",
  "settings": [
    {
      "type": "header",
      "content": "Menú de navegación"
    },
    {
      "type": "text",
      "id": "link_1_label",
      "label": "Enlace 1 — texto",
      "default": "Inicio"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Enlace 1 — URL",
      "default": "/"
    },
    {
      "type": "text",
      "id": "link_2_label",
      "label": "Enlace 2 — texto",
      "default": "Catálogo"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Enlace 2 — URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "link_3_label",
      "label": "Enlace 3 — texto",
      "default": "Acuerdos"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Enlace 3 — URL",
      "default": "/pages/acuerdos"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "nav_bg",
      "label": "Fondo del menú",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "nav_color",
      "label": "Color del texto",
      "default": "#ffffff"
    }
  ],
  "presets": [{ "name": "3D Logo" }]
}
{% endschema %}