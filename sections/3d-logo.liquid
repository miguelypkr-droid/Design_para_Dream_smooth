    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    transition: opacity 0.2s;
  }
  .l3d-mob-link:hover { opacity: 0.65; }

  /* Acordeon catálogo */
  .l3d-mob-accordion { border-bottom: 1px solid rgba(255,255,255,0.07); }
  .l3d-mob-accordion-btn {
    width: 100%;
    background: none;
    border: none;
    color: {{ section.settings.nav_color }};
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.08em;
