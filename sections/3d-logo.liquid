    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    pointer-events: none;
  }

  .l3d-link {
    color: {{ section.settings.nav_color }};
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .l3d-link:hover {
    opacity: 0.65;
  }

  /* Contenedor del dropdown — padding-bottom crea un puente invisible sobre el gap */
  .l3d-dropdown {
    position: relative;
    display: flex;
    align-items: center;
    padding-bottom: 1rem;
    margin-bottom: -1rem;
  }

  /* Submenú oculto por defecto */
  .l3d-submenu {
    display: none;
    position: absolute;
    top: calc(100% - 1rem + 0.8rem);
    left: 50%;
    transform: translateX(-50%);
    background: {{ section.settings.nav_bg }};
    min-width: 280px;
    padding: 1.1rem 1.4rem;
    flex-direction: row;
    gap: 1rem;
    align-items: flex-start;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
    border-top: 2px solid rgba(255,255,255,0.12);
    z-index: 9999;
  }

  /* Aparece al hacer hover con animación slide desde arriba */
  .l3d-dropdown:hover .l3d-submenu {
    display: flex;
    animation: l3d-slide-down 0.22s ease forwards;
  }

  @keyframes l3d-slide-down {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Grupo dentro del submenú */
  .l3d-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .l3d-group-title {
    color: {{ section.settings.nav_color }};
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 0.25rem;
  }

  .l3d-sub-link {
    color: {{ section.settings.nav_color }};
    text-decoration: none;
    font-size: 0.83rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .l3d-sub-link:hover {
    opacity: 0.55;
  }

  /* Línea divisoria entre grupos */
  .l3d-divider {
    width: 1px;
    background: rgba(255,255,255,0.15);
    align-self: stretch;
    margin: 0 0.25rem;
  }
