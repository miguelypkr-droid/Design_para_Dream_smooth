<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

<div class="logo3d-box">
  <model-viewer
    src="https://cdn.shopify.com/3d/models/o/d49653b2167972d2/Dreamsmoothlogo.glb"
    auto-rotate
    rotation-per-second="-30deg"
    camera-controls
    disable-zoom
    interaction-prompt="none"
  ></model-viewer>
</div>

<style>
  .logo3d-box {
    width: 100%;
    background: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 0;
  }

  .logo3d-box model-viewer {
    width: 120px;
    height: 120px;
    background: transparent;
    display: block;
  }
</style>

{% schema %}
{
  "name": "3D Logo",
  "settings": [],
  "presets": [{ "name": "3D Logo" }]
}
{% endschema %}