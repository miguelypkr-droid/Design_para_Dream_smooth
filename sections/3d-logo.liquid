<div id="logo3d-{{ section.id }}" class="logo3d-wrap"></div>

<style>
  .logo3d-wrap {
    width: 100%;
    height: clamp(320px, 55vw, 640px);
    background: #000;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }
  .logo3d-wrap:active { cursor: grabbing; }
  .logo3d-wrap canvas { display: block; width: 100% !important; height: 100% !important; }
</style>

<script type="module">
  import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160/build/three.module.js';
  import { GLTFLoader }  from 'https://cdn.jsdelivr.net/npm/three@0.160/examples/jsm/loaders/GLTFLoader.js';
  import { OrbitControls } from 'https://cdn.jsdelivr.net/npm/three@0.160/examples/jsm/controls/OrbitControls.js';

  const container = document.getElementById('logo3d-{{ section.id }}');

  /* ── Scene ── */
  const scene = new THREE.Scene();

  /* ── Camera ── */
  const camera = new THREE.PerspectiveCamera(40, container.clientWidth / container.clientHeight, 0.01, 1000);
  camera.position.set(0, 0, 5);

  /* ── Renderer ── */
  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.2;
  container.appendChild(renderer.domElement);

  /* ── Lights ── */
  scene.add(new THREE.AmbientLight(0xffffff, 1.2));

  const key = new THREE.DirectionalLight(0xffffff, 2.5);
  key.position.set(4, 6, 5);
  scene.add(key);

  const fill = new THREE.DirectionalLight(0xddeeff, 1.0);
  fill.position.set(-4, 2, -3);
  scene.add(fill);

  const rim = new THREE.DirectionalLight(0xfff4cc, 0.8);
  rim.position.set(0, -4, -5);
  scene.add(rim);

  /* ── Controls ── */
  const controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping    = true;
  controls.dampingFactor    = 0.07;
  controls.enableZoom       = false;
  controls.enablePan        = false;
  controls.rotateSpeed      = 0.9;
  /* allow full 360° on both axes */
  controls.minPolarAngle    = 0;
  controls.maxPolarAngle    = Math.PI;

  /* Auto-rotation state */
  let autoRotate  = true;
  let idleTimer   = null;
  const RESUME_MS = 2000; // ms after releasing mouse before auto-rotate resumes

  controls.addEventListener('start', () => {
    autoRotate = false;
    clearTimeout(idleTimer);
  });
  controls.addEventListener('end', () => {
    idleTimer = setTimeout(() => { autoRotate = true; }, RESUME_MS);
  });

  /* ── Load model ── */
  const loader = new GLTFLoader();
  loader.load(
    'https://cdn.shopify.com/3d/models/o/253b3a20f29932b7/dreamsmoothlogo.glb',
    (gltf) => {
      const model = gltf.scene;

      /* Center and scale to fit the view */
      const box    = new THREE.Box3().setFromObject(model);
      const center = new THREE.Vector3();
      const size   = new THREE.Vector3();
      box.getCenter(center);
      box.getSize(size);

      const maxDim  = Math.max(size.x, size.y, size.z);
      const scale   = 2.8 / maxDim;
      model.scale.setScalar(scale);
      model.position.sub(center.multiplyScalar(scale));

      scene.add(model);
      controls.target.set(0, 0, 0);
      controls.update();

      animate();
    },
    undefined,
    (err) => console.error('[3D Logo] GLTFLoader error:', err)
  );

  /* ── Resize ── */
  const onResize = () => {
    const w = container.clientWidth;
    const h = container.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  };
  window.addEventListener('resize', onResize);

  /* ── Render loop ── */
  function animate() {
    requestAnimationFrame(animate);
    if (autoRotate) controls.object.position.applyAxisAngle(
      new THREE.Vector3(0, 1, 0), 0.003
    );
    controls.update();
    renderer.render(scene, camera);
  }
</script>

{% schema %}
{
  "name": "3D Logo",
  "settings": [],
  "presets": [
    {
      "name": "3D Logo"
    }
  ]
}
{% endschema %}