<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

<!-- Contenedor sticky -->
<div class="l3d-sticky-header">

<!-- Barra de envíos -->
<div class="l3d-shipping-bar">
  <span>✈ Envíos a todo el mundo por: DHL y EMS</span>
</div>

<!-- Caja 1: Logo 3D -->
<div class="l3d-logo-box" style="width:100%; background:#000000; display:flex; justify-content:center; align-items:center; padding:2.5rem 0 4rem 0; box-sizing:border-box; position:relative; overflow:hidden; min-height:220px;">
  <model-viewer
    src="https://cdn.shopify.com/3d/models/o/d49653b2167972d2/Dreamsmoothlogo.glb"
    auto-rotate
    rotation-per-second="-30deg"
    camera-controls
    disable-zoom
    interaction-prompt="none"
    style="width:180px; height:180px; background:transparent; display:block;"
  ></model-viewer>
</div>

<!-- Caja 2: Barra de navegación -->
<div class="l3d-nav-bar">

  <!-- Iconos sociales (izquierda) -->
  <div class="l3d-social-icons">
    <a href="{{ section.settings.instagram_url }}" class="l3d-social-link" target="_blank" rel="noopener" aria-label="Instagram">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
      </svg>
    </a>
    <a href="{{ section.settings.whatsapp_url }}" class="l3d-social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.558 4.121 1.531 5.853L.057 23.55a.75.75 0 0 0 .916.916l5.697-1.474A11.953 11.953 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.724 9.724 0 0 1-4.998-1.376l-.358-.214-3.712.96.983-3.598-.234-.371A9.724 9.724 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
      </svg>
    </a>
  </div>

  <!-- Links centrales -->

  <div class="l3d-nav-links">
    <a href="{{ section.settings.link_1_url }}" class="l3d-link">{{ section.settings.link_1_label }}</a>
  <div class="l3d-dropdown">
    <a href="{{ section.settings.link_2_url }}" class="l3d-link">{{ section.settings.link_2_label }}</a>
    <div class="l3d-submenu">
      <div class="l3d-group">
        <span class="l3d-group-title">Marcas</span>
        <a href="{{ section.settings.sub_marca_1_url }}" class="l3d-sub-link">Polo Ralph Lauren</a>
        <a href="{{ section.settings.sub_marca_2_url }}" class="l3d-sub-link">Dream Smooth</a>
        <a href="{{ section.settings.sub_marca_4_url }}" class="l3d-sub-link">Adidas</a>
        <a href="{{ section.settings.sub_marca_3_url }}" class="l3d-sub-link">Otros</a>
      </div>
      <div class="l3d-divider"></div>
      <div class="l3d-group">
        <span class="l3d-group-title">Estado</span>
        <a href="{{ section.settings.sub_estado_1_url }}" class="l3d-sub-link">Nuevo</a>
        <a href="{{ section.settings.sub_estado_2_url }}" class="l3d-sub-link">Usado</a>
      </div>
    </div>
  </div>

    <a href="{{ section.settings.link_3_url }}" class="l3d-link">{{ section.settings.link_3_label }}</a>
  </div>

  <!-- Selector de idioma + Carrito (derecha) -->
  <div class="l3d-right-group">

    {%- if localization.available_languages.size > 1 -%}
    <form action="/localization" method="POST" class="l3d-lang-form">
      <input type="hidden" name="_method" value="PUT">
      <input type="hidden" name="return_to" value="{{ request.path }}">
      <div class="l3d-lang-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        <select name="locale_code" class="l3d-lang-select" onchange="this.form.submit()" aria-label="Idioma">
          {%- for language in localization.available_languages -%}
            <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
              {{ language.endonym_name }}
            </option>
          {%- endfor -%}
        </select>
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="l3d-lang-chevron">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </form>
    {%- endif -%}

    <!-- Lupa de búsqueda -->
    <a href="/search" class="l3d-cart-link" aria-label="Buscar">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </a>

    <!-- Carrito -->
    <a href="/cart" class="l3d-cart-link" aria-label="Carrito">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      {%- if cart.item_count > 0 -%}
        <span class="l3d-cart-count">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>

  </div>

</div>

</div><!-- fin l3d-sticky-header -->

<script>
  (function () {
    function removeTopSpace() {
      var el = document.querySelector('.l3d-sticky-header');
      if (!el) return;
      var section = el.closest('.shopify-section');
      if (section) {
        section.style.setProperty('margin-top', '0', 'important');
        section.style.setProperty('padding-top', '0', 'important');
        section.style.setProperty('height', '0', 'important');
        section.style.setProperty('min-height', '0', 'important');
      }
      /* Sobreescribir variables CSS del tema Dawn */
      document.documentElement.style.setProperty('--header-group-height', '0px', 'important');
      document.documentElement.style.setProperty('--header-height', '0px', 'important');
      /* Compensar el espacio que ocupa el header fijo en el contenido */
      function applyOffset() {
        var h = el.offsetHeight;
        var main = document.getElementById('MainContent') || document.querySelector('main');
        if (main) main.style.setProperty('padding-top', h + 'px', 'important');
      }
      applyOffset();
      window.addEventListener('resize', applyOffset);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', removeTopSpace);
    } else {
      removeTopSpace();
    }
  })();

  /* ---- Efecto bolitas en la caja del logo ---- */
  (function () {
    function spawnSnow() {
      var box = document.querySelector('.l3d-logo-box');
      if (!box) return;
      var total = 40;
      for (var i = 0; i < total; i++) {
        var dot = document.createElement('span');
        var size = 2 + Math.random() * 5;
        dot.style.cssText = [
          'position:absolute',
          'border-radius:50%',
          'background:rgba(255,255,255,' + (0.35 + Math.random() * 0.65) + ')',
          'width:' + size + 'px',
          'height:' + size + 'px',
          'left:' + (Math.random() * 98) + '%',
          'top:' + (Math.random() * 98) + '%',
          'pointer-events:none',
          'animation:l3d-snow-twinkle ' + (1.5 + Math.random() * 3.5) + 's ease-in-out ' + (Math.random() * 5) + 's infinite'
        ].join(';');
        box.appendChild(dot);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', spawnSnow);
    } else {
      spawnSnow();
    }
  })();
</script>

<style>
  /* Bolitas brillando por toda la caja */
  @keyframes l3d-snow-twinkle {
    0%,100% { opacity: 0.15; transform: scale(0.8); }
    30%     { opacity: 1;    transform: scale(1.4); }
    60%     { opacity: 0.5;  transform: scale(1);   }
  }

  /* Eliminar espacio blanco superior del tema */
  :root {
    --header-group-height: 0px !important;
    --header-height: 0px !important;
  }
  .shopify-section:has(.l3d-shipping-bar) {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }
  #MainContent,
  .content-for-layout {
    padding-top: 0 !important;
    margin-top: 0 !important;
  }

  /* Header fijo + animación de entrada */
  @keyframes l3d-header-in {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }

  .l3d-sticky-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    width: 100%;
    animation: l3d-header-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }



  .l3d-shipping-bar {
    width: 100%;
    background: {{ section.settings.nav_bg }};
    display: flex;
    justify-content: center;
    align-items: flex-end;
    padding: 1.2rem 2rem 0.5rem;
    box-sizing: border-box;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .l3d-shipping-bar span {
    color: {{ section.settings.nav_color }};
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .l3d-nav-bar {
    width: 100%;
    background: {{ section.settings.nav_bg }};
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 2rem;
    box-sizing: border-box;
    position: relative;
  }

  .l3d-nav-links {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .l3d-social-icons {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .l3d-social-link {
    color: #ffffff;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }

  .l3d-social-link:hover {
    opacity: 0.6;
  }

  /* Carrito */
  .l3d-cart-wrapper,
  .l3d-right-group {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  /* Selector de idioma */
  .l3d-lang-form {
    margin: 0;
    padding: 0;
  }

  .l3d-lang-wrapper {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: #ffffff;
    cursor: pointer;
  }

  .l3d-lang-select {
    background: transparent;
    border: none;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
    padding: 0;
    margin: 0;
  }

  .l3d-lang-select option {
    background: {{ section.settings.nav_bg }};
    color: {{ section.settings.nav_color }};
  }

  .l3d-lang-chevron {
    pointer-events: none;
  }
    display: flex;
    align-items: center;
  }

  .l3d-cart-link {
    position: relative;
    color: #ffffff !important;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .l3d-cart-link svg,
  .l3d-cart-link svg * {
    stroke: #ffffff !important;
    fill: none !important;
  }

  .l3d-cart-link:hover {
    opacity: 0.6;
  }

  .l3d-cart-count {
    position: absolute;
    top: -7px;
    right: -9px;
    background: {{ section.settings.nav_color }};
    color: {{ section.settings.nav_bg }};
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
  }

  .l3d-link {
    color: {{ section.settings.nav_color }};
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .l3d-link:hover {
    opacity: 0.65;
  }

  /* Contenedor del dropdown — padding-bottom crea un puente invisible sobre el gap */
  .l3d-dropdown {
    position: relative;
    display: flex;
    align-items: center;
    padding-bottom: 1rem;
    margin-bottom: -1rem;
  }

  /* Submenú oculto por defecto */
  .l3d-submenu {
    display: none;
    position: absolute;
    top: calc(100% - 1rem + 0.8rem);
    left: 50%;
    transform: translateX(-50%);
    background: {{ section.settings.nav_bg }};
    min-width: 280px;
    padding: 1.1rem 1.4rem;
    flex-direction: row;
    gap: 1rem;
    align-items: flex-start;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
    border-top: 2px solid rgba(255,255,255,0.12);
    z-index: 9999;
  }

  /* Aparece al hacer hover con animación slide desde arriba */
  .l3d-dropdown:hover .l3d-submenu {
    display: flex;
    animation: l3d-slide-down 0.22s ease forwards;
  }

  @keyframes l3d-slide-down {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Grupo dentro del submenú */
  .l3d-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .l3d-group-title {
    color: {{ section.settings.nav_color }};
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 0.25rem;
  }

  .l3d-sub-link {
    color: {{ section.settings.nav_color }};
    text-decoration: none;
    font-size: 0.83rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .l3d-sub-link:hover {
    opacity: 0.55;
  }

  /* Línea divisoria entre grupos */
  .l3d-divider {
    width: 1px;
    background: rgba(255,255,255,0.15);
    align-self: stretch;
    margin: 0 0.25rem;
  }
</style>

