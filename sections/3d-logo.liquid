    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 2rem;
    box-sizing: border-box;
    position: relative;
  }

  /* ---- Luna con bandera ---- */
  .l3d-moon-scene {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 1;
    filter: drop-shadow(0 0 16px rgba(210,215,255,0.55));
  }

  /* ---- Sol ---- */
  .l3d-sun-scene {
    position: absolute;
    top: 0;
    right: 0;
    pointer-events: none;
    z-index: 1;
    filter: drop-shadow(0 0 22px rgba(255,220,60,0.55));
  }

  /* ---- Asteroides ---- */
  .l3d-asteroid {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    filter: drop-shadow(0 0 4px rgba(210,215,255,0.55));
  }
  #l3d-ast-1 { animation: l3d-ast-fly-1  6s linear infinite; animation-delay:  0s; }
  #l3d-ast-2 { animation: l3d-ast-fly-2  9s linear infinite; animation-delay: -3.6s; }
  #l3d-ast-3 { animation: l3d-ast-fly-3  4.5s linear infinite; animation-delay: -1.8s; }
  #l3d-ast-4 { animation: l3d-ast-fly-4 12s linear infinite; animation-delay: -7s; }

  @keyframes l3d-ast-fly-1 {
    0%   { left: 103%; top:  8%; transform: rotate(0deg);    opacity: 0; }
    6%   {                                                   opacity: 1; }
    94%  {                                                   opacity: 1; }
    100% { left:  -4%; top: 72%; transform: rotate(-220deg); opacity: 0; }
  }
  @keyframes l3d-ast-fly-2 {
    0%   { left:  -3%; top: 20%; transform: rotate(0deg);   opacity: 0; }
    6%   {                                                  opacity: 1; }
    94%  {                                                  opacity: 1; }
    100% { left: 104%; top: 60%; transform: rotate(190deg); opacity: 0; }
  }
  @keyframes l3d-ast-fly-3 {
    0%   { left: 70%;  top: -5%; transform: rotate(0deg);   opacity: 0; }
    8%   {                                                  opacity: 1; }
    92%  {                                                  opacity: 1; }
    100% { left: 88%;  top: 110%; transform: rotate(310deg); opacity: 0; }
  }
  @keyframes l3d-ast-fly-4 {
    0%   { left: 103%; top: 35%; transform: rotate(0deg);   opacity: 0; }
    5%   {                                                  opacity: 1; }
    95%  {                                                  opacity: 1; }
    100% { left:  -4%; top: 15%; transform: rotate(160deg); opacity: 0; }
  }

  /* ---- Satélite ---- */
  .l3d-satellite {
    position: absolute;
    pointer-events: none;
    z-index: 2;
    filter: drop-shadow(0 0 4px rgba(150,190,255,0.55));
    animation: l3d-sat-orbit 22s linear infinite;
    animation-delay: -8s;
  }
  @keyframes l3d-sat-orbit {
    0%   { left: -8%;  top: 28%; opacity: 0; }
    5%   {             top: 28%; opacity: 1; }
    95%  {             top: 52%; opacity: 1; }
    100% { left: 106%; top: 52%; opacity: 0; }
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 1400px) {
