          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </form>
    {%- endif -%}

    <!-- Lupa de búsqueda -->
    <a href="/search" class="l3d-cart-link" aria-label="Buscar">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </a>

    <!-- Carrito -->
    <a href="/cart" class="l3d-cart-link" aria-label="Carrito">
      <span class="l3d-cart-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="l3d-cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
