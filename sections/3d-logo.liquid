<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

<!-- Contenedor sticky -->
<div class="l3d-sticky-header">

<!-- Barra de envíos -->
<div class="l3d-shipping-bar">
  <span>✈ Envíos a todo el mundo por: DHL y EMS</span>
</div>

<!-- Caja 1: Logo 3D -->
<div style="width:100%; background:#000000; display:flex; justify-content:center; align-items:center; padding:0.4rem 0; box-sizing:border-box;">
  <model-viewer
    src="https://cdn.shopify.com/3d/models/o/d49653b2167972d2/Dreamsmoothlogo.glb"
    auto-rotate
    rotation-per-second="-30deg"
    camera-controls
    disable-zoom
    interaction-prompt="none"
    style="width:180px; height:180px; background:transparent; display:block;"
  ></model-viewer>
</div>

<!-- Caja 2: Barra de navegación -->
<div class="l3d-nav-bar">

  <!-- Iconos sociales (izquierda) -->
  <div class="l3d-social-icons">
    <a href="{{ section.settings.instagram_url }}" class="l3d-social-link" target="_blank" rel="noopener" aria-label="Instagram">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
      </svg>
    </a>
    <a href="{{ section.settings.whatsapp_url }}" class="l3d-social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
