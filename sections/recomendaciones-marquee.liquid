<div class="reco-section" id="reco-section-{{ section.id }}">

  <div class="reco-dots">
    {% for i in (1..60) %}
      {% assign top = i | times: 37 | modulo: 100 %}
      {% assign left = i | times: 53 | modulo: 100 %}
      {% assign delay = i | times: 13 | modulo: 40 %}
      {% assign delay_dec = delay | append: '00' %}
      {% assign dur = i | times: 7 | modulo: 30 | plus: 20 %}
      <span class="reco-dot" style="top:{{ top }}%; left:{{ left }}%; animation-delay:{{ delay_dec | prepend: '0.' | remove: '0.0' | prepend: '0.' }}s; animation-duration:{{ dur }}00ms;"></span>
    {% endfor %}
  </div>

  {% if section.settings.heading != blank %}
    <div class="reco-heading-bar">
      <h2 class="reco-heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="reco-rows">
    {% assign all_blocks = section.blocks %}
    {% assign row1 = '' %}
    {% assign total = all_blocks.size %}

    {% for row_index in (0..2) %}
      {% assign direction_class = 'reco-scroll-left' %}
      {% if row_index == 1 %}
        {% assign direction_class = 'reco-scroll-right' %}
      {% endif %}

      <div class="reco-row-wrapper">
        <div class="reco-row {{ direction_class }}">

          {% comment %} Repetimos el track dos veces para lograr el loop infinito {% endcomment %}
          {% for repeat in (1..2) %}
            <div class="reco-track">
              {% for block in all_blocks %}
                {% assign block_position = forloop.index0 | modulo: 3 %}
                {% if block_position == row_index %}
                  <div class="reco-card" {{ block.shopify_attributes }}>
                    <div class="reco-card-topbar">
                      {{ section.settings.card_label | default: 'Recomendaciones' }}
                    </div>
                    <div class="reco-card-body">
                      <p class="reco-card-username">
                        {{ block.settings.customer_name | default: 'Usuario' }}
                      </p>
                      <p class="reco-card-text">
                        {{ block.settings.recommendation | default: 'Excelente experiencia de compra, totalmente recomendado.' }}
                      </p>
                      <div class="reco-card-stars">
                        {% assign rating = block.settings.rating | default: 5 %}
                        {% for star in (1..5) %}
                          {% if star <= rating %}
                            <svg class="reco-star reco-star-filled" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26 6.91 1.01-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
                          {% else %}
                            <svg class="reco-star reco-star-empty" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26 6.91 1.01-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endfor %}

        </div>
      </div>
    {% endfor %}
  </div>

</div>

{% stylesheet %}
  .reco-section {
    position: relative;
    background-color: #000000;
    padding: 60px 0;
    overflow: hidden;
    isolation: isolate;
  }

  /* ---- Puntos parpadeantes de fondo ---- */
  .reco-dots {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .reco-dot {
    position: absolute;
    width: 3px;
    height: 3px;
    background: #ffffff;
    border-radius: 50%;
    opacity: 0.15;
    animation-name: reco-twinkle;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
  }

  @keyframes reco-twinkle {
    0%   { opacity: 0.05; transform: scale(1); }
    50%  { opacity: 1;    transform: scale(1.6); }
    100% { opacity: 0.05; transform: scale(1); }
  }

  /* ---- Título como barra ---- */
  .reco-heading-bar {
    position: relative;
    z-index: 2;
    max-width: 640px;
    margin: 0 auto 40px;
    background-color: #0a0a0a;
    border: 1px solid #6b6b6b;
    border-radius: 8px;
    padding: 14px 24px;
    animation: reco-border-glow 2.4s ease-in-out infinite;
  }

  .reco-heading {
    text-align: center;
    color: #ffffff;
    font-size: 26px;
    margin: 0;
    letter-spacing: 0.5px;
  }

  @keyframes reco-border-glow {
    0%   { border-color: #4a4a4a; box-shadow: 0 0 0px rgba(255,255,255,0); }
    50%  { border-color: #ffffff; box-shadow: 0 0 12px rgba(255,255,255,0.5); }
    100% { border-color: #4a4a4a; box-shadow: 0 0 0px rgba(255,255,255,0); }
  }

  /* ---- Filas ---- */
  .reco-rows {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .reco-row-wrapper {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 60px, black calc(100% - 60px), transparent 100%);
    mask-image: linear-gradient(to right, transparent 0, black 60px, black calc(100% - 60px), transparent 100%);
  }

  .reco-row {
    display: flex;
    width: max-content;
  }

  .reco-track {
    display: flex;
    gap: 18px;
    padding: 0 9px;
    flex-shrink: 0;
  }

  .reco-scroll-left {
    animation: reco-marquee-left 40s linear infinite;
  }

  .reco-scroll-right {
    animation: reco-marquee-right 40s linear infinite;
  }

  .reco-row-wrapper:hover .reco-row {
    animation-play-state: paused;
  }

  @keyframes reco-marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes reco-marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* ---- Tarjetas ---- */
  .reco-card {
    background-color: #2b2b2b;
    border-radius: 10px;
    width: 300px;
    flex-shrink: 0;
    overflow: hidden;
    border: 1px solid #3d3d3d;
    box-shadow: 0 4px 14px rgba(0,0,0,0.4);
  }

  .reco-card-topbar {
    background-color: #1a1a1a;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 8px 14px;
    border-bottom: 1px solid #3d3d3d;
  }

  .reco-card-body {
    padding: 16px 16px 18px;
  }

  .reco-card-username {
    color: #ffffff;
    font-weight: 700;
    font-size: 14px;
    margin: 0 0 8px;
  }

  .reco-card-text {
    color: #cfcfcf;
    font-size: 13.5px;
    line-height: 1.5;
    margin: 0;
  }

  /* ---- Estrellas ---- */
  .reco-card-stars {
    display: flex;
    gap: 3px;
    margin-top: 10px;
  }

  .reco-star {
    width: 16px;
    height: 16px;
  }

  .reco-star-filled {
    fill: #f5c518;
  }

  .reco-star-empty {
    fill: #4a4a4a;
  }

  @media screen and (max-width: 749px) {
    .reco-card { width: 240px; }
    .reco-heading { font-size: 20px; }
    .reco-heading-bar { padding: 12px 18px; max-width: 90%; }
  }
{% endstylesheet %}

