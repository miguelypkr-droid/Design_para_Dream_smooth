<div
  class="section section--{{ section.settings.section_width }} spacing-style"
  style="background: {{ section.settings.bg_color }}; position: relative; overflow: hidden; {% render 'spacing-style', settings: section.settings %}"
>
  <canvas class="criticas__starfield" aria-hidden="true"></canvas>

  {%- comment -%} Barra superior {%- endcomment -%}
  <div class="criticas__bar">
    <span class="criticas__bar-text">{{ section.settings.bar_text }}</span>
  </div>

  {%- comment -%} Carrusel de reseñas (bloques) {%- endcomment -%}
  <div class="criticas__carousel-wrapper">
    <button class="criticas__arrow criticas__arrow--prev" aria-label="Anterior">&#8592;</button>
    <div class="criticas__grid">
    {%- for block in section.blocks -%}
      {%- assign reviewer_photo = block.settings.reviewer_photo -%}
      {%- assign reviewer_name  = block.settings.reviewer_name -%}
      {%- assign review_text    = block.settings.review_text -%}
      {%- assign review_image   = block.settings.review_image -%}

      <div class="criticas__item" {{ block.shopify_attributes }}>

        {%- comment -%} Foto circular encima de la tarjeta {%- endcomment -%}
        <div class="criticas__avatar-wrap">
          {%- if reviewer_photo != blank -%}
            {{
              reviewer_photo
              | image_url: width: 180
              | image_tag:
                class: 'criticas__avatar',
                alt: reviewer_name,
                width: reviewer_photo.width,
                height: reviewer_photo.height
            }}
          {%- else -%}
            <div class="criticas__avatar-placeholder">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="20" cy="14" r="8" fill="rgba(255,255,255,0.3)"/>
                <ellipse cx="20" cy="33" rx="13" ry="8" fill="rgba(255,255,255,0.15)"/>
              </svg>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Tarjeta con nombre, texto e imagen inferior {%- endcomment -%}
        <div class="criticas__card">
          <span class="criticas__name" style="color: {{ section.settings.text_color }};">
            {%- if reviewer_name != blank -%}{{ reviewer_name }}{%- else -%}Cliente{%- endif -%}
          </span>

          <p class="criticas__text" style="color: {{ section.settings.text_color }};">
            {%- if review_text != blank -%}
              {{ review_text }}
            {%- else -%}
              Una experiencia increíble. Totalmente recomendado.
            {%- endif -%}
          </p>

          {%- if review_image != blank -%}
            <div class="criticas__bottom-image-wrap">
              {{
                review_image
                | image_url: width: 600
                | image_tag:
                  class: 'criticas__bottom-image',
                  alt: reviewer_name,
                  width: review_image.width,
                  height: review_image.height,
                  loading: 'lazy'
              }}
            </div>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
    </div>
    <button class="criticas__arrow criticas__arrow--next" aria-label="Siguiente">&#8594;</button>
  </div>
</div>

<style>
  .criticas__starfield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  .criticas__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    margin-bottom: 36px;
    width: 100vw;
    position: relative;
    left: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    background-color: #111111;
    color: #ffffff;
    z-index: 1;
  }

  .criticas__bar-text {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: inherit;
  }

  .criticas__carousel-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  .criticas__arrow {
    flex-shrink: 0;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.35);
    color: #ffffff;
    font-size: 1.2rem;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 2;
    line-height: 1;
  }

  .criticas__arrow--visible {
    display: flex;
  }

  .criticas__arrow:hover {
    background: rgba(255,255,255,0.25);
  }

  .criticas__arrow--prev { margin-right: 10px; }
  .criticas__arrow--next { margin-left: 10px; }

  .criticas__grid {
    display: flex;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding-bottom: 10px;
    scrollbar-width: none;
  }

  .criticas__grid::-webkit-scrollbar {
    display: none;
  }

  .criticas__item {
    flex: 0 0 calc(25% - 12px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
  }

  @media screen and (max-width: 989px) {
    .criticas__item {
      flex: 0 0 calc(33.333% - 11px);
    }
  }

  @media screen and (max-width: 749px) {
    .criticas__item {
      flex: 0 0 72vw;
    }
  }

  /* Circular avatar — overlaps the card top */
  .criticas__avatar-wrap {
    position: relative;
    z-index: 1;
    margin-bottom: -34px;
    width: 68px;
    height: 68px;
    flex-shrink: 0;
  }

  .criticas__avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    display: block;
    border: 3px solid #1a1a1a;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.12);
  }

  .criticas__avatar-placeholder {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: #222222;
    border: 3px solid #1a1a1a;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .criticas__avatar-placeholder svg {
    width: 36px;
    height: 36px;
  }

  /* Card */
  .criticas__card {
    width: 100%;
    background: #111111;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 44px 16px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .criticas__name {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1.2;
  }

  .criticas__text {
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
    margin: 0;
  }

  .criticas__bottom-image-wrap {
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    margin-top: 4px;
  }

  .criticas__bottom-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
  }
</style>

<script>
(function () {
  function initStarfield(section) {
    var canvas = section.querySelector('.criticas__starfield');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var stars = [];
    var raf;

    function buildStars() {
      canvas.width  = section.offsetWidth  || 1200;
      canvas.height = section.offsetHeight || 600;
      stars = [];
      for (var i = 0; i < 120; i++) {
        stars.push({
          x:     Math.random() * canvas.width,
          y:     Math.random() * canvas.height,
          r:     Math.random() * 1.4 + 0.3,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.012 + 0.004
        });
      }
      for (var j = 0; j < 60; j++) {
        stars.push({
          x:     Math.random() * canvas.width * 0.35,
          y:     Math.random() * canvas.height,
          r:     Math.random() * 1.2 + 0.2,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.012 + 0.004
        });
      }
    }

    function draw(t) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var time = t * 0.001;
      for (var i = 0; i < stars.length; i++) {
        var s = stars[i];
        var opacity = 0.15 + 0.75 * (0.5 + 0.5 * Math.sin(time * s.speed * 60 + s.phase));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, 6.2832);
        ctx.fillStyle = 'rgba(255,255,255,' + opacity.toFixed(3) + ')';
        ctx.fill();
      }
      raf = requestAnimationFrame(draw);
    }

    buildStars();
    raf = requestAnimationFrame(draw);

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        cancelAnimationFrame(raf);
        buildStars();
        raf = requestAnimationFrame(draw);
      }, 150);
    });
  }

  document.querySelectorAll('.criticas__starfield').forEach(function (canvas) {
    initStarfield(canvas.closest('.section'));
  });

  // Arrow navigation
  document.querySelectorAll('.criticas__carousel-wrapper').forEach(function (wrapper) {
    var grid = wrapper.querySelector('.criticas__grid');
    var prev = wrapper.querySelector('.criticas__arrow--prev');
    var next = wrapper.querySelector('.criticas__arrow--next');
    if (!grid || !prev || !next) return;

    function updateArrowVisibility() {
      var scrollable = grid.scrollWidth > grid.clientWidth + 2;
      prev.classList.toggle('criticas__arrow--visible', scrollable);
      next.classList.toggle('criticas__arrow--visible', scrollable);
    }

    function scrollBy(dir) {
      var item = grid.querySelector('.criticas__item');
      if (!item) return;
      var amount = item.offsetWidth + 16;
      grid.scrollBy({ left: dir * amount, behavior: 'smooth' });
    }

    prev.addEventListener('click', function () { scrollBy(-1); });
    next.addEventListener('click', function () { scrollBy(1); });

    updateArrowVisibility();
    window.addEventListener('resize', updateArrowVisibility);
  });
})();
</script>

{% schema %}
{
  "name": "Críticas",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "resena",
      "name": "Reseña",
      "settings": [
        {
          "type": "image_picker",
          "id": "reviewer_photo",
          "label": "Foto del cliente"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Nombre",
          "default": "Cliente"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Texto de la reseña",
          "default": "Una experiencia increíble. Totalmente recomendado."
        },
        {
          "type": "image_picker",
          "id": "review_image",
          "label": "Imagen inferior"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "bar_text",
      "label": "Texto de la barra",
      "default": "Reseñas"
    },
    {
      "type": "header",
      "content": "Diseño de sección"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de la sección",
      "options": [
        { "value": "full-width", "label": "Completo" },
        { "value": "page-width", "label": "Página" },
        { "value": "narrow",     "label": "Angosto"  }
      ],
      "default": "page-width"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacio superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacio inferior",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Críticas",
      "blocks": [
        { "type": "resena" },
        { "type": "resena" },
        { "type": "resena" },
        { "type": "resena" },
        { "type": "resena" },
        { "type": "resena" }
      ]
    }
  ]
}
{% endschema %}
