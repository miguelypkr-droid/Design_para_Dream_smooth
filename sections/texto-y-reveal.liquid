<div class="tyv-section" style="background: {{ section.settings.bg_color }};">
  <div class="tyv-dots-layer"></div>
  <div class="tyv-inner">

    <!-- Columna izquierda: texto -->
    <div class="tyv-text-col">
      {%- if section.settings.eyebrow != blank -%}
        <p class="tyv-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="tyv-heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="tyv-body" style="color: {{ section.settings.text_color }};">
          {{ section.settings.body }}
        </div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
        <a href="{{ section.settings.btn_url }}" class="tyv-btn"
           style="background: {{ section.settings.btn_bg }}; color: {{ section.settings.btn_color }};">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>

    <!-- Columna derecha: Image Reveal Lens -->
    <div class="tyv-video-col">
      <div
        id="ir-wrap-{{ section.id }}"
        style="
          position: relative;
          width: 100%;
          max-width: {{ section.settings.video_max_width }}px;
          overflow: hidden;
          border-radius: {{ section.settings.video_radius }}px;
          aspect-ratio: {{ section.settings.aspect_ratio }};
          cursor: none;
          -webkit-tap-highlight-color: transparent;
        "
      >

        <!-- Imagen base -->
        <div style="position:absolute;inset:0;z-index:1;">
          {%- if section.settings.image_base != blank -%}
            <img
              src="{{ section.settings.image_base | image_url: width: 1800 }}"
              alt="{{ section.settings.image_base.alt | escape }}"
              loading="eager"
              style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;user-select:none;"
              draggable="false"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:#1a1a2e;display:flex;align-items:center;justify-content:center;">
              <span style="color:rgba(255,255,255,0.25);font-family:sans-serif;letter-spacing:.1em;font-size:.85rem;">IMAGEN PRINCIPAL</span>
            </div>
          {%- endif -%}
        </div>

        <!-- Imagen revelada -->
        <div
          id="ir-rev-{{ section.id }}"
          style="position:absolute;inset:0;z-index:2;clip-path:circle(0px at -999px -999px);will-change:clip-path;"
        >
          {%- if section.settings.image_reveal != blank -%}
            <img
              src="{{ section.settings.image_reveal | image_url: width: 1800 }}"
              alt="{{ section.settings.image_reveal.alt | escape }}"
              loading="eager"
              style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;user-select:none;"
              draggable="false"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#e94560,#f5a623);display:flex;align-items:center;justify-content:center;">
              <span style="color:rgba(255,255,255,0.4);font-family:sans-serif;letter-spacing:.1em;font-size:.85rem;">IMAGEN REVELADA</span>
            </div>
          {%- endif -%}
        </div>

        <!-- Cursor visual -->
        <div
          id="ir-cur-{{ section.id }}"
          style="position:absolute;top:0;left:0;z-index:10;pointer-events:none;opacity:0;will-change:transform;"
        >
          <div style="width:{{ section.settings.lens_size }}px;height:{{ section.settings.lens_size }}px;border-radius:50%;border:2px solid rgba(255,255,255,0.75);transform:translate(-50%,-50%);position:relative;">
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:6px;height:6px;border-radius:50%;background:#fff;"></div>
          </div>
        </div>

        <!-- Hint -->
        {%- unless section.settings.hide_hint -%}
        <div
          id="ir-hint-{{ section.id }}"
          style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:15;pointer-events:none;text-align:center;transition:opacity .3s;"
        >
          <div style="width:50px;height:50px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.5);display:flex;align-items:center;justify-content:center;margin:0 auto 8px;animation:irpulse 2s ease-in-out infinite;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="13"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <span style="font-family:sans-serif;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.5);">{{ section.settings.hint_text | default: 'Pasa el cursor para revelar' }}</span>
        </div>
        {%- endunless -%}

        <!-- Etiqueta opcional -->
        {%- if section.settings.label_text != blank -%}
        <div style="position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);z-index:20;pointer-events:none;font-family:sans-serif;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.5);background:rgba(0,0,0,.35);padding:.3rem .9rem;border-radius:999px;border:1px solid rgba(255,255,255,.12);white-space:nowrap;">{{ section.settings.label_text }}</div>
        {%- endif -%}

      </div>
    </div>

  </div>
</div>

<style>
  @keyframes tyv-twinkle {
    0%,100% { opacity: 0.10; transform: scale(0.8); }
    30%     { opacity: 1;    transform: scale(1.5); }
    60%     { opacity: 0.45; transform: scale(1);   }
  }
  @keyframes irpulse {
    0%,100% { transform: scale(1); opacity: .5; }
    50%     { transform: scale(1.2); opacity: 1; }
  }

  .tyv-section {
    width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  .tyv-dots-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .tyv-inner {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    flex-wrap: wrap;
  }

  @keyframes tyv-fade-left {
    from { opacity: 0; transform: translateX(-48px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes tyv-fade-right {
    from { opacity: 0; transform: translateX(48px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .tyv-text-col {
    flex: 1 1 320px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    opacity: 0;
    {%- if section.settings.text_align == 'center' -%}
    align-items: center;
    text-align: center;
    {%- elsif section.settings.text_align == 'right' -%}
    align-items: flex-end;
    text-align: right;
    {%- else -%}
    align-items: flex-start;
    text-align: left;
    {%- endif -%}
  }

  .tyv-inner.tyv-visible .tyv-text-col {
    animation: tyv-fade-left 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  .tyv-video-col {
    flex: 1 1 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
  }

  .tyv-inner.tyv-visible .tyv-video-col {
    animation: tyv-fade-right 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  .tyv-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0;
  }

  .tyv-heading {
    font-size: clamp(1.6rem, 3.5vw, {{ section.settings.heading_size }}px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
  }

  .tyv-body {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    margin: 0;
    max-width: 520px;
  }

  .tyv-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.4rem;
  }

  .tyv-btn:hover { opacity: 0.78; }

  @media (max-width: 768px) {
    .tyv-inner { flex-direction: column; gap: 2rem; }
    .tyv-video-col, .tyv-text-col { width: 100%; }
    #ir-wrap-{{ section.id }} { cursor: default; }
  }
</style>

<script>
  (function () {
    /* ---- Animaciones de entrada con IntersectionObserver ---- */
    function initAnimations() {
      var inner = document.querySelector('.tyv-inner');
      if (!inner) return;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            inner.classList.add('tyv-visible');
            observer.disconnect();
          }
        });
      }, { threshold: 0.12 });
      observer.observe(inner);
    }

    /* ---- Dots de fondo ---- */
    function spawnDots() {
      var layer = document.querySelector('.tyv-dots-layer');
      if (!layer) return;
      for (var i = 0; i < 50; i++) {
        var dot = document.createElement('span');
        var size = 2 + Math.random() * 5;
        dot.style.cssText = [
          'position:absolute',
          'border-radius:50%',
          'background:rgba(255,255,255,' + (0.3 + Math.random() * 0.7) + ')',
          'width:' + size + 'px',
          'height:' + size + 'px',
          'left:' + (Math.random() * 99) + '%',
          'top:' + (Math.random() * 99) + '%',
          'pointer-events:none',
          'animation:tyv-twinkle ' + (1.5 + Math.random() * 3.5) + 's ease-in-out ' + (Math.random() * 5) + 's infinite'
        ].join(';');
        layer.appendChild(dot);
      }
    }

    /* ---- Image Reveal Lens ---- */
    function initLens() {
      var wrap   = document.getElementById('ir-wrap-{{ section.id }}');
      var rev    = document.getElementById('ir-rev-{{ section.id }}');
      var cur    = document.getElementById('ir-cur-{{ section.id }}');
      var hint   = document.getElementById('ir-hint-{{ section.id }}');
      if (!wrap || !rev) return;

      var LENS   = {{ section.settings.lens_size | default: 200 }};
      var SMOOTH = {{ section.settings.smoothing | default: 6 }};
      var half   = LENS / 2;
      var tx = -9999, ty = -9999, cx = -9999, cy = -9999;
      var on = false, raf = null;

      function render() {
        if (!on) { raf = null; return; }
        cx += (tx - cx) / SMOOTH;
        cy += (ty - cy) / SMOOTH;
        rev.style.clipPath = 'circle(' + half + 'px at ' + Math.round(cx) + 'px ' + Math.round(cy) + 'px)';
        if (cur) cur.style.transform = 'translate(' + Math.round(cx) + 'px,' + Math.round(cy) + 'px)';
        raf = requestAnimationFrame(render);
      }

      function xy(clientX, clientY) {
        var r = wrap.getBoundingClientRect();
        return { x: clientX - r.left, y: clientY - r.top };
      }

      function start(clientX, clientY) {
        on = true;
        var p = xy(clientX, clientY); tx = p.x; ty = p.y;
        if (cur)  cur.style.opacity  = '1';
        if (hint) hint.style.opacity = '0';
        if (!raf) raf = requestAnimationFrame(render);
      }

      function stop() {
        on = false;
        rev.style.clipPath = 'circle(0px at ' + Math.round(cx) + 'px ' + Math.round(cy) + 'px)';
        if (cur)  cur.style.opacity  = '0';
        if (hint) hint.style.opacity = '1';
        tx = -9999; ty = -9999; cx = -9999; cy = -9999;
        if (raf) { cancelAnimationFrame(raf); raf = null; }
      }

      wrap.addEventListener('mouseenter', function(e) { start(e.clientX, e.clientY); });
      wrap.addEventListener('mousemove',  function(e) { var p = xy(e.clientX, e.clientY); tx = p.x; ty = p.y; });
      wrap.addEventListener('mouseleave', stop);

      wrap.addEventListener('touchstart',  function(e) { if (e.touches[0]) start(e.touches[0].clientX, e.touches[0].clientY); }, { passive: true });
      wrap.addEventListener('touchmove',   function(e) { e.preventDefault(); if (e.touches[0]) { var p = xy(e.touches[0].clientX, e.touches[0].clientY); tx = p.x; ty = p.y; } }, { passive: false });
      wrap.addEventListener('touchend',    stop);
      wrap.addEventListener('touchcancel', stop);
    }

    function init() {
      initAnimations();
      spawnDots();
      initLens();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% schema %}
{
  "name": "Texto y Reveal Lens",
  "settings": [
    {
      "type": "header",
      "content": "Diseño general"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Relleno vertical (px)",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Ancho máximo del contenido (px)",
      "min": 600,
      "max": 1600,
      "step": 40,
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre columnas (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación del texto",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior (eyebrow)",
      "default": "Sobre nosotros"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color eyebrow",
      "default": "#888888"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Quiénes somos"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño máximo del título (px)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 48
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Cuerpo del texto",
      "default": "<p>Escribe aquí una descripción de tu sitio o marca.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del cuerpo",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del cuerpo (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Botón (opcional)"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "URL del botón"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Fondo del botón",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Color del texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Imágenes (Reveal Lens)"
    },
    {
      "type": "image_picker",
      "id": "image_base",
      "label": "Imagen principal"
    },
    {
      "type": "image_picker",
      "id": "image_reveal",
      "label": "Imagen revelada (bajo el lente)"
    },
    {
      "type": "header",
      "content": "Lente"
    },
    {
      "type": "range",
      "id": "lens_size",
      "label": "Tamaño del lente (px)",
      "min": 80,
      "max": 500,
      "step": 10,
      "default": 200
    },
    {
      "type": "range",
      "id": "smoothing",
      "label": "Suavizado (1 directo · 12 fluido)",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Layout de la imagen"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Proporción de la imagen",
      "options": [
        { "value": "16/9", "label": "16:9 Panorámica" },
        { "value": "4/3",  "label": "4:3 Clásica" },
        { "value": "1/1",  "label": "1:1 Cuadrada" },
        { "value": "3/2",  "label": "3:2 Fotografía" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "video_max_width",
      "label": "Ancho máximo de la imagen (px)",
      "min": 160,
      "max": 900,
      "step": 20,
      "default": 560
    },
    {
      "type": "range",
      "id": "video_radius",
      "label": "Radio de bordes (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Indicador"
    },
    {
      "type": "checkbox",
      "id": "hide_hint",
      "label": "Ocultar indicador de interacción",
      "default": false
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Texto del indicador",
      "default": "Pasa el cursor para revelar"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Etiqueta sobre la imagen (opcional)",
      "placeholder": "Ej: Antes / Después"
    }
  ],
  "presets": [
    {
      "name": "Texto y Reveal Lens",
      "category": "Image"
    }
  ]
}
{% endschema %}
