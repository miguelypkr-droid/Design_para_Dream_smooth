<!-- Popup código de descuento -->
<div class="tyv-gift-popup" id="tyv-gift-popup" aria-hidden="true" style="display:none;">
  <button class="tyv-gift-close" id="tyv-gift-close" aria-label="Cerrar">&times;</button>
  <p class="tyv-gift-title">🎁 ¡Tu regalo!</p>
  <p class="tyv-gift-subtitle">Código de descuento</p>
  <div class="tyv-gift-code">DREAMCODE2026</div>
  <button class="tyv-gift-copy" id="tyv-gift-copy">Copiar código</button>
  <p class="tyv-gift-hint">Úsalo en tu próxima compra</p>
</div>

<style>
  @keyframes tyv-twinkle {
    0%,100% { opacity: 0.10; transform: scale(0.8); }
    30%     { opacity: 1;    transform: scale(1.5); }
    60%     { opacity: 0.45; transform: scale(1);   }
  }

  .tyv-section {
    width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  .tyv-dots-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .tyv-inner {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    flex-wrap: wrap;
  }

  /* ---- Animaciones de entrada ---- */
  @keyframes tyv-fade-left {
    from { opacity: 0; transform: translateX(-48px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes tyv-fade-right {
    from { opacity: 0; transform: translateX(48px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Columna texto ---- */
  .tyv-text-col {
    flex: 1 1 320px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    opacity: 0;
    {%- if section.settings.text_align == 'center' -%}
    align-items: center;
    text-align: center;
    {%- elsif section.settings.text_align == 'right' -%}
    align-items: flex-end;
    text-align: right;
    {%- else -%}
    align-items: flex-start;
    text-align: left;
    {%- endif -%}
  }

  .tyv-inner.tyv-visible .tyv-text-col {
    animation: tyv-fade-left 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  /* Columna video ---- */
  .tyv-video-col {
    flex: 1 1 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
  }

  .tyv-inner.tyv-visible .tyv-video-col {
    animation: tyv-fade-right 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  .tyv-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0;
  }

  .tyv-heading {
    font-size: clamp(1.6rem, 3.5vw, {{ section.settings.heading_size }}px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
  }

  .tyv-body {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    margin: 0;
    max-width: 520px;
  }

  .tyv-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.4rem;
  }

  .tyv-btn:hover { opacity: 0.78; }

  /* ---- Columna video ---- */
  .tyv-video-col {

  .tyv-video-wrap {
    width: 100%;
    max-width: {{ section.settings.video_max_width }}px;
    overflow: visible;
    line-height: 0;
    position: relative;
  }

  /* ---- Sello Prenda trend ---- */
  .tyv-stamp {
    position: absolute;
    top: -1.2rem;
    right: -1.6rem;
    z-index: 3;
    background: rgba(190, 20, 20, 0.93);
    color: #fff;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    border: 2.5px solid rgba(255,255,255,0.75);
    box-shadow: inset 0 0 0 1px rgba(190,20,20,0.5), 2px 3px 12px rgba(0,0,0,0.45);
    transform: rotate(22deg);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.25;
    pointer-events: none;
    user-select: none;
    gap: 0.05rem;
  }
  .tyv-stamp span:first-child {
    font-size: 0.78rem;
    opacity: 0.88;
  }
  .tyv-stamp span:last-child {
    font-size: 1.05rem;
  }

  .tyv-video-wrap video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Capa invisible que bloquea clicks sobre el video (impide menú contextual) */
  .tyv-video-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: all;
  }

  /* ---- Dato curioso ---- */
  .tyv-fun-fact {
    margin: 0.9rem 0 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.72);
    background: rgba(255,255,255,0.07);
    border-left: 3px solid rgba(255,255,255,0.35);
    padding: 0.55rem 0.9rem;
    border-radius: 0 4px 4px 0;
    max-width: {{ section.settings.video_max_width }}px;
  }
  .tyv-fun-fact-label {
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
  }

  /* ---- Regalo flotante ---- */
  @keyframes tyv-gift-float {
    0%   { transform: translate(0px,   0px)   rotate(-6deg) scale(1);    }
    15%  { transform: translate(-14px,-20px)  rotate( 4deg) scale(1.05); }
    30%  { transform: translate( 10px,-34px)  rotate(-2deg) scale(0.97); }
    50%  { transform: translate( 18px,-16px)  rotate( 9deg) scale(1.03); }
    70%  { transform: translate(  4px,-28px)  rotate(-5deg) scale(1.06); }
    85%  { transform: translate(-10px, -8px)  rotate( 3deg) scale(0.98); }
    100% { transform: translate(0px,   0px)   rotate(-6deg) scale(1);    }
  }
  @keyframes tyv-sparkle-spin {
    0%   { transform: rotate(0deg)   scale(1);   }
    50%  { transform: rotate(180deg) scale(1.3); }
    100% { transform: rotate(360deg) scale(1);   }
  }
  @keyframes tyv-popup-in {
    from { opacity: 0; transform: translateY(16px) scale(0.92); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }
  .tyv-gift {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 9000;
    cursor: pointer;
    animation: tyv-gift-float 3s ease-in-out infinite;
    filter: drop-shadow(0 4px 16px rgba(255,255,255,0.22));
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .tyv-gift:hover { filter: drop-shadow(0 4px 28px rgba(255,255,255,0.45)); }
  .tyv-gift-sparkle {
    position: absolute;
    top: -8px;
    right: -6px;
    font-size: 1rem;
    animation: tyv-sparkle-spin 2.2s linear infinite;
    pointer-events: none;
  }
  .tyv-gift-popup {
    position: fixed;
    bottom: 8rem;
    right: 2rem;
    z-index: 9001;
    background: #1a1a25;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 12px;
    padding: 1.4rem 1.6rem;
    width: 230px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.04);
    text-align: center;
    display: none;
  }
  .tyv-gift-popup.tyv-popup-visible {
    display: block;
    animation: tyv-popup-in 0.28s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .tyv-gift-close {
    position: absolute;
    top: 0.45rem;
    right: 0.7rem;
    background: none;
    border: none;
    color: rgba(255,255,255,0.45);
    font-size: 1.3rem;
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }
  .tyv-gift-close:hover { color: #fff; }
  .tyv-gift-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.25rem;
  }
  .tyv-gift-subtitle {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.5);
    margin: 0 0 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .tyv-gift-code {
    background: rgba(255,255,255,0.07);
    border: 1.5px dashed rgba(255,255,255,0.32);
    border-radius: 6px;
    padding: 0.5rem 0.8rem;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: #fff;
    margin-bottom: 0.75rem;
    font-family: monospace;
  }
  .tyv-gift-copy {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.22);
    color: #fff;
    border-radius: 6px;
    padding: 0.45rem 0;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    width: 100%;
  }
  .tyv-gift-copy:hover  { background: rgba(255,255,255,0.2); }
  .tyv-gift-copy.tyv-copied { background: rgba(50,190,90,0.22); border-color: rgba(50,190,90,0.5); }
  .tyv-gift-hint {
    font-size: 0.66rem;
    color: rgba(255,255,255,0.3);
    margin: 0.55rem 0 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .tyv-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .tyv-video-col { width: 100%; }
    .tyv-text-col  { width: 100%; }
  }
</style>

<script>
  (function () {
    /* ---- Animaciones de entrada con IntersectionObserver ---- */
    function initAnimations() {
      var inner = document.querySelector('.tyv-inner');
      if (!inner) return;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            inner.classList.add('tyv-visible');
            observer.disconnect();
          }
        });
      }, { threshold: 0.12 });
      observer.observe(inner);
    }

    /* ---- Bucle de video reforzado por JS ---- */
    function ensureLoop() {
      document.querySelectorAll('.tyv-video-wrap video').forEach(function (v) {
        v.loop = true;
        /* timeupdate: reinicia 0.25s antes del final para evitar el flash de pantalla negra */
        v.addEventListener('timeupdate', function () {
          if (v.duration && v.currentTime >= v.duration - 0.25) {
            v.currentTime = 0;
          }
        });
        v.addEventListener('ended', function () {
          v.currentTime = 0;
          v.play().catch(function () {});
        });
      });
    }

    function init() { initAnimations(); ensureLoop(); }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();

  (function () {
    function spawnDots() {
      var layer = document.querySelector('.tyv-dots-layer');
      if (!layer) return;
      var total = 50;
      for (var i = 0; i < total; i++) {
        var dot = document.createElement('span');
        var size = 2 + Math.random() * 5;
        dot.style.cssText = [
          'position:absolute',
          'border-radius:50%',
          'background:rgba(255,255,255,' + (0.3 + Math.random() * 0.7) + ')',
          'width:' + size + 'px',
          'height:' + size + 'px',
          'left:' + (Math.random() * 99) + '%',
          'top:' + (Math.random() * 99) + '%',
          'pointer-events:none',
          'animation:tyv-twinkle ' + (1.5 + Math.random() * 3.5) + 's ease-in-out ' + (Math.random() * 5) + 's infinite'
        ].join(';');
        layer.appendChild(dot);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', spawnDots);
    } else {
      spawnDots();
    }
  })();

  (function () {
    function spawnAsteroids() {
      var section = document.querySelector('.tyv-section');
      if (!section) return;

      var rocks = [
        {
          id: 'r1', size: 26,
          clip: 'polygon(28% 0%,72% 4%,96% 28%,100% 68%,78% 96%,38% 100%,8% 82%,0% 42%)',
          from: 'translate(-90px,15vh)',  to: 'translate(calc(100vw + 100px),58vh)',
          spin: 420,  dur: 9,  delay: 0
        },
        {
          id: 'r2', size: 18,
          clip: 'polygon(50% 0%,88% 14%,100% 52%,82% 90%,48% 100%,12% 88%,0% 50%,18% 12%)',
          from: 'translate(38vw,-90px)',  to: 'translate(72vw,calc(100vh + 100px))',
          spin: -360, dur: 11, delay: 2.5
        },
        {
          id: 'r3', size: 32,
          clip: 'polygon(22% 5%,62% 0%,94% 24%,100% 62%,80% 96%,44% 100%,10% 86%,0% 52%,6% 22%)',
          from: 'translate(calc(100vw + 90px),28vh)', to: 'translate(-110px,72vh)',
          spin: -520, dur: 13, delay: 5
        },
        {
          id: 'r4', size: 20,
          clip: 'polygon(42% 0%,80% 8%,100% 42%,90% 80%,60% 100%,20% 98%,0% 68%,6% 28%)',
          from: 'translate(-90px,68vh)',  to: 'translate(calc(100vw + 100px),18vh)',
          spin: 300,  dur: 8,  delay: 1.5
        },
        {
          id: 'r5', size: 22,
          clip: 'polygon(55% 0%,92% 18%,100% 58%,76% 94%,38% 100%,6% 76%,0% 36%,26% 4%)',
          from: 'translate(82vw,-90px)',  to: 'translate(-90px,calc(100vh + 90px))',
          spin: 480,  dur: 10, delay: 7
        },
        {
          id: 'r6', size: 15,
          clip: 'polygon(34% 0%,72% 2%,100% 36%,96% 72%,66% 100%,24% 100%,0% 64%,4% 26%)',
          from: 'translate(-80px,44vh)',  to: 'translate(calc(100vw + 80px),8vh)',
          spin: -280, dur: 12, delay: 3.8
        },
        {
          id: 'r7', size: 28,
          clip: 'polygon(46% 2%,84% 10%,100% 48%,88% 86%,52% 100%,14% 92%,0% 54%,10% 16%)',
          from: 'translate(54vw,calc(100vh + 90px))', to: 'translate(8vw,-110px)',
          spin: 400,  dur: 14, delay: 4.5
        }
      ];

      /* inyectar keyframes dinámicos */
      var styleEl = document.createElement('style');
      styleEl.textContent = rocks.map(function (r) {
        return '@keyframes tyv-rock-' + r.id + '{' +
          '0%{transform:' + r.from + ' rotate(0deg);opacity:0}' +
          '7%{opacity:0.88}' +
          '90%{opacity:0.82}' +
          '100%{transform:' + r.to + ' rotate(' + r.spin + 'deg);opacity:0}}';
      }).join('');
      document.head.appendChild(styleEl);

      rocks.forEach(function (r) {
        var el = document.createElement('div');
        el.style.cssText = [
          'position:absolute',
          'top:0',
          'left:0',
          'width:' + r.size + 'px',
          'height:' + r.size + 'px',
          'background:rgba(225,225,232,0.86)',
          'clip-path:' + r.clip,
          'box-shadow:0 0 6px 2px rgba(255,255,255,0.35)',
          'pointer-events:none',
          'z-index:0',
          'will-change:transform,opacity',
          'animation:tyv-rock-' + r.id + ' ' + r.dur + 's linear ' + r.delay + 's infinite'
        ].join(';');
        section.appendChild(el);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', spawnAsteroids);
    } else {
      spawnAsteroids();
    }
  })();

  (function () {
    function initGift() {
      var gift   = document.getElementById('tyv-gift');
      var popup  = document.getElementById('tyv-gift-popup');
      var closeBtn = document.getElementById('tyv-gift-close');
      var copyBtn  = document.getElementById('tyv-gift-copy');
      if (!gift || !popup) return;

      function togglePopup(e) {
        e.stopPropagation();
        var visible = popup.style.display === 'block';
        popup.style.display = visible ? 'none' : 'block';
        popup.setAttribute('aria-hidden', visible);
        if (!visible) popup.style.animation = 'none';
        requestAnimationFrame(function() {
          if (popup.style.display === 'block') {
            popup.style.animation = '';
          }
        });
      }
      gift.addEventListener('click', togglePopup);
      gift.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') togglePopup(e);
      });

      closeBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        popup.style.display = 'none';
        popup.setAttribute('aria-hidden', 'true');
      });

      copyBtn.addEventListener('click', function () {
        var code = 'DREAMCODE2026';
        function markCopied() {
          copyBtn.textContent = '¡Copiado! ✓';
          copyBtn.classList.add('tyv-copied');
          setTimeout(function () {
            copyBtn.textContent = 'Copiar código';
            copyBtn.classList.remove('tyv-copied');
          }, 2200);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(markCopied).catch(function () {
            fallbackCopy(code); markCopied();
          });
        } else {
          fallbackCopy(code); markCopied();
        }
      });

      function fallbackCopy(text) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
        document.body.appendChild(ta);
        ta.focus(); ta.select();
        try { document.execCommand('copy'); } catch(e) {}
        document.body.removeChild(ta);
      }

      document.addEventListener('click', function (e) {
        if (!gift.contains(e.target) && !popup.contains(e.target)) {
          popup.style.display = 'none';
          popup.setAttribute('aria-hidden', 'true');
        }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGift);
    } else {
      initGift();
    }
  })();
</script>

