    <circle cx="38" cy="31" r="1.2" fill="rgba(255,255,255,0.50)"/>
    <circle cx="50" cy="52" r="1"   fill="rgba(255,255,255,0.60)"/>
    <circle cx="16" cy="56" r="0.8" fill="rgba(255,255,255,0.45)"/>
    <circle cx="45" cy="40" r="1.3" fill="rgba(255,255,255,0.35)"/>
    <circle cx="28" cy="57" r="1"   fill="rgba(255,255,255,0.50)"/>
    <circle cx="54" cy="35" r="0.9" fill="rgba(255,255,255,0.40)"/>
    <rect x="27" y="24" width="6" height="36" fill="rgba(255,255,255,0.65)" rx="1"/>
