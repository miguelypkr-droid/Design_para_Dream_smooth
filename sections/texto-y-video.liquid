<div class="tyv-section" style="background: {{ section.settings.bg_color }};">
  <div class="tyv-dots-layer"></div>
  <div class="tyv-inner">

    <!-- Columna izquierda: texto -->
    <div class="tyv-text-col">
      {%- if section.settings.eyebrow != blank -%}
        <p class="tyv-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="tyv-heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="tyv-body" style="color: {{ section.settings.text_color }};">
          {{ section.settings.body }}
        </div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
        <a href="{{ section.settings.btn_url }}" class="tyv-btn"
           style="background: {{ section.settings.btn_bg }}; color: {{ section.settings.btn_color }};">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>

    <!-- Columna derecha: video -->
    <div class="tyv-video-col">
      {%- if section.settings.video_url != blank -%}
        <div class="tyv-video-wrap" style="border-radius: {{ section.settings.video_radius }}px;">
          <video
            src="{{ section.settings.video_url }}"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablePictureInPicture
            controlsList="nodownload nofullscreen noremoteplayback noplaybackrate"
            style="pointer-events: none;"
          ></video>
          <div class="tyv-stamp"><span>Prenda</span><span>trend</span></div>
        </div>
      {%- elsif section.settings.video_shopify != blank -%}
        <div class="tyv-video-wrap" style="border-radius: {{ section.settings.video_radius }}px;">
          <video
            src="{{ section.settings.video_shopify }}"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablePictureInPicture
            controlsList="nodownload nofullscreen noremoteplayback noplaybackrate"
            style="pointer-events: none;"
          ></video>
          <div class="tyv-stamp"><span>Prenda</span><span>trend</span></div>
        </div>
      {%- endif -%}
    </div>

  </div>

  <!-- Velas decorativas izquierda -->
  <div class="tyv-candle-left">
    <svg xmlns="http://www.w3.org/2000/svg" width="100" height="220" viewBox="0 0 100 220" aria-hidden="true">
      <!-- Vela 1: alta, intacta, encendida -->
      <rect x="14" y="60" width="16" height="160" rx="2" fill="#f5f0e8" stroke="#ddd" stroke-width="0.5"/>
      <line x1="22" y1="52" x2="22" y2="60" stroke="#333" stroke-width="1.2" stroke-linecap="round"/>
      <ellipse class="tyv-flame-glow" cx="22" cy="44" rx="11" ry="8" fill="#ffcc44" opacity="0.3"/>
      <g class="tyv-flame" style="animation-delay:0s">
        <path d="M22,22 C30,34 32,46 22,52 C12,46 14,34 22,22Z" fill="#ff7700"/>
        <path d="M22,25 C27,36 29,44 22,50 C15,44 17,36 22,25Z" fill="#ffcc00"/>
        <path d="M22,29 C25,37 26,43 22,48 C18,43 19,37 22,29Z" fill="#fffde0"/>
      </g>
      <circle cx="22" cy="60" r="1.5" fill="#ff5500"/>
      <!-- Vela 2: media, derritiéndose, encendida -->
      <ellipse cx="72" cy="219" rx="14" ry="3" fill="#f0e8d8"/>
      <rect x="64" y="115" width="16" height="105" rx="2" fill="#f5f0e8" stroke="#ddd" stroke-width="0.5"/>
      <path d="M80,122 C82,132 82,142 80,150 C79,155 78,148 79,138 C79,130 79,125 80,122Z" fill="#f0e8d8"/>
      <path d="M64,128 C62,138 62,148 64,155 C65,160 66,153 65,143 C64,135 64,131 64,128Z" fill="#f0e8d8"/>
      <line x1="72" y1="107" x2="72" y2="115" stroke="#333" stroke-width="1.2" stroke-linecap="round"/>
      <ellipse class="tyv-flame-glow" cx="72" cy="99" rx="11" ry="8" fill="#ffcc44" opacity="0.3" style="animation-delay:0.8s"/>
      <g class="tyv-flame" style="animation-delay:0.4s">
        <path d="M72,77 C80,89 82,101 72,107 C62,101 64,89 72,77Z" fill="#ff7700"/>
        <path d="M72,80 C77,91 79,99 72,105 C65,99 67,91 72,80Z" fill="#ffcc00"/>
        <path d="M72,84 C75,92 76,98 72,103 C68,98 69,92 72,84Z" fill="#fffde0"/>
      </g>
      <circle cx="72" cy="115" r="1.5" fill="#ff5500"/>
    </svg>
  </div>

  <!-- Velas decorativas derecha -->
  <div class="tyv-candle-right">
    <svg xmlns="http://www.w3.org/2000/svg" width="165" height="220" viewBox="0 0 165 220" aria-hidden="true">
      <!-- Vela 3: la más alta, intacta, encendida -->
      <rect x="14" y="40" width="16" height="180" rx="2" fill="#f5f0e8" stroke="#ddd" stroke-width="0.5"/>
      <line x1="22" y1="32" x2="22" y2="40" stroke="#333" stroke-width="1.2" stroke-linecap="round"/>
      <ellipse class="tyv-flame-glow" cx="22" cy="24" rx="11" ry="8" fill="#ffcc44" opacity="0.3" style="animation-delay:0.2s"/>
      <g class="tyv-flame" style="animation-delay:0.2s">
        <path d="M22,2 C30,14 32,26 22,32 C12,26 14,14 22,2Z" fill="#ff7700"/>
        <path d="M22,5 C27,16 29,24 22,30 C15,24 17,16 22,5Z" fill="#ffcc00"/>
        <path d="M22,9 C25,17 26,23 22,28 C18,23 19,17 22,9Z" fill="#fffde0"/>
      </g>
      <circle cx="22" cy="40" r="1.5" fill="#ff5500"/>
      <!-- Vela 4: media, una gota, encendida -->
      <ellipse cx="82" cy="219" rx="13" ry="3" fill="#f0e8d8"/>
      <rect x="74" y="100" width="16" height="120" rx="2" fill="#f5f0e8" stroke="#ddd" stroke-width="0.5"/>
      <path d="M74,108 C72,118 72,128 74,136 C75,141 76,134 75,124 C75,116 74,111 74,108Z" fill="#f0e8d8"/>
      <line x1="82" y1="91" x2="82" y2="100" stroke="#333" stroke-width="1.2" stroke-linecap="round"/>
      <ellipse class="tyv-flame-glow" cx="82" cy="83" rx="11" ry="8" fill="#ffcc44" opacity="0.3" style="animation-delay:1.1s"/>
      <g class="tyv-flame" style="animation-delay:0.6s">
        <path d="M82,61 C90,73 92,85 82,91 C72,85 74,73 82,61Z" fill="#ff7700"/>
        <path d="M82,64 C87,75 89,83 82,89 C75,83 77,75 82,64Z" fill="#ffcc00"/>
        <path d="M82,68 C85,76 86,82 82,87 C78,82 79,76 82,68Z" fill="#fffde0"/>
      </g>
      <circle cx="82" cy="100" r="1.5" fill="#ff5500"/>
      <!-- Vela 5: corta, muy derretida, APAGADA -->
      <ellipse cx="138" cy="219" rx="18" ry="4" fill="#f0e8d8"/>
      <ellipse cx="138" cy="216" rx="14" ry="2.5" fill="#e8ddc8"/>
      <rect x="130" y="175" width="16" height="45" rx="2" fill="#f5f0e8" stroke="#ddd" stroke-width="0.5"/>
      <path d="M146,180 C149,192 149,204 147,212 C145,218 144,210 145,198 C145,188 146,183 146,180Z" fill="#f0e8d8"/>
      <path d="M130,183 C127,195 127,207 129,215 C131,219 132,212 131,200 C130,190 130,186 130,183Z" fill="#f0e8d8"/>
      <path d="M140,178 C141,186 141,194 139,200 C138,204 137,198 138,190 C138,184 140,181 140,178Z" fill="#f0e8d8"/>
      <path d="M138,175 C139,171 141,167 143,163" stroke="#555" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      <path d="M143,163 C144,156 142,149 143,142 C144,135 146,128 144,121" stroke="#aaa" stroke-width="1" stroke-linecap="round" stroke-dasharray="2,4" fill="none"/>
    </svg>
  </div>
</div>

<style>
  @keyframes tyv-twinkle {
    0%,100% { opacity: 0.10; transform: scale(0.8); }
    30%     { opacity: 1;    transform: scale(1.5); }
    60%     { opacity: 0.45; transform: scale(1);   }
  }

  .tyv-section {
    width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  .tyv-dots-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .tyv-inner {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    flex-wrap: wrap;
  }

  /* ---- Animaciones de entrada ---- */
  @keyframes tyv-fade-left {
    from { opacity: 0; transform: translateX(-48px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes tyv-fade-right {
    from { opacity: 0; transform: translateX(48px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Columna texto ---- */
  .tyv-text-col {
    flex: 1 1 320px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    opacity: 0;
    {%- if section.settings.text_align == 'center' -%}
    align-items: center;
    text-align: center;
    {%- elsif section.settings.text_align == 'right' -%}
    align-items: flex-end;
    text-align: right;
    {%- else -%}
    align-items: flex-start;
    text-align: left;
    {%- endif -%}
  }

  .tyv-inner.tyv-visible .tyv-text-col {
    animation: tyv-fade-left 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  /* Columna video ---- */
  .tyv-video-col {
    flex: 1 1 320px;
    display: flex;
    justify-content: center;
    opacity: 0;
  }

  .tyv-inner.tyv-visible .tyv-video-col {
    animation: tyv-fade-right 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  .tyv-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0;
  }

  .tyv-heading {
    font-size: clamp(1.6rem, 3.5vw, {{ section.settings.heading_size }}px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
  }

  .tyv-body {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    margin: 0;
    max-width: 520px;
  }

  .tyv-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.4rem;
  }

  .tyv-btn:hover { opacity: 0.78; }

  /* ---- Columna video ---- */
  .tyv-video-col {

  .tyv-video-wrap {
    width: 100%;
    max-width: {{ section.settings.video_max_width }}px;
    overflow: visible;
    line-height: 0;
    position: relative;
  }

  /* ---- Sello Prenda trend ---- */
  .tyv-stamp {
    position: absolute;
    top: -1.2rem;
    right: -1.6rem;
    z-index: 3;
    background: rgba(22, 130, 50, 0.93);
    color: #fff;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    border: 2.5px solid rgba(255,255,255,0.75);
    box-shadow: inset 0 0 0 1px rgba(22,130,50,0.5), 2px 3px 12px rgba(0,0,0,0.45);
    transform: rotate(22deg);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.25;
    pointer-events: none;
    user-select: none;
    gap: 0.05rem;
  }
  .tyv-stamp span:first-child {
    font-size: 0.78rem;
    opacity: 0.88;
  }
  .tyv-stamp span:last-child {
    font-size: 1.05rem;
  }

  .tyv-video-wrap video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Capa invisible que bloquea clicks sobre el video (impide menú contextual) */
  .tyv-video-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: all;
  }

  /* ---- Velas decorativas ---- */
  .tyv-candle-left,
  .tyv-candle-right {
    position: absolute;
    bottom: 0;
    pointer-events: none;
    z-index: 2;
    line-height: 0;
  }
  .tyv-candle-left  { left:  1.5rem; }
  .tyv-candle-right { right: 1.5rem; }

  @keyframes tyv-flame-flicker {
    0%   { transform: rotate(-3deg) scaleX(0.92); }
    25%  { transform: rotate( 2deg) scaleX(1.06); }
    65%  { transform: rotate(-1deg) scaleX(0.97); }
    100% { transform: rotate( 4deg) scaleX(1.04); }
  }
  @keyframes tyv-glow-pulse {
    from { opacity: 0.12; transform: scale(1);    }
    to   { opacity: 0.40; transform: scale(1.35); }
  }
  .tyv-flame {
    transform-box: fill-box;
    transform-origin: center bottom;
    animation: tyv-flame-flicker 0.65s ease-in-out infinite alternate;
  }
  .tyv-flame-glow {
    transform-box: fill-box;
    transform-origin: center center;
    animation: tyv-glow-pulse 1.3s ease-in-out infinite alternate;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .tyv-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .tyv-video-col { width: 100%; }
    .tyv-text-col  { width: 100%; }
    .tyv-candle-left  { left:  0.25rem; }
    .tyv-candle-right { right: 0.25rem; }
    .tyv-candle-left svg  { transform: scale(0.6); transform-origin: bottom left; }
    .tyv-candle-right svg { transform: scale(0.6); transform-origin: bottom right; }
  }
</style>

<script>
  (function () {
    /* ---- Animaciones de entrada con IntersectionObserver ---- */
    function initAnimations() {
      var inner = document.querySelector('.tyv-inner');
      if (!inner) return;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            inner.classList.add('tyv-visible');
            observer.disconnect();
          }
        });
      }, { threshold: 0.12 });
      observer.observe(inner);
    }

    /* ---- Bucle de video reforzado por JS ---- */
    function ensureLoop() {
      document.querySelectorAll('.tyv-video-wrap video').forEach(function (v) {
        v.loop = true;
        /* timeupdate: reinicia 0.25s antes del final para evitar el flash de pantalla negra */
        v.addEventListener('timeupdate', function () {
          if (v.duration && v.currentTime >= v.duration - 0.25) {
            v.currentTime = 0;
          }
        });
        v.addEventListener('ended', function () {
          v.currentTime = 0;
          v.play().catch(function () {});
        });
      });
    }

    function init() { initAnimations(); ensureLoop(); }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();

  (function () {
    function spawnDots() {
      var layer = document.querySelector('.tyv-dots-layer');
      if (!layer) return;
      var total = 50;
      for (var i = 0; i < total; i++) {
        var dot = document.createElement('span');
        var size = 2 + Math.random() * 5;
        dot.style.cssText = [
          'position:absolute',
          'border-radius:50%',
          'background:rgba(255,255,255,' + (0.3 + Math.random() * 0.7) + ')',
          'width:' + size + 'px',
          'height:' + size + 'px',
          'left:' + (Math.random() * 99) + '%',
          'top:' + (Math.random() * 99) + '%',
          'pointer-events:none',
          'animation:tyv-twinkle ' + (1.5 + Math.random() * 3.5) + 's ease-in-out ' + (Math.random() * 5) + 's infinite'
        ].join(';');
        layer.appendChild(dot);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', spawnDots);
    } else {
      spawnDots();
    }
  })();
</script>

{% schema %}
{
  "name": "Texto y Video",
  "settings": [
    {
      "type": "header",
      "content": "Diseño general"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Relleno vertical (px)",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Ancho máximo del contenido (px)",
      "min": 600,
      "max": 1600,
      "step": 40,
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre columnas (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación del texto",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior (eyebrow)",
      "default": "Sobre nosotros"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color eyebrow",
      "default": "#888888"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Quiénes somos"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño máximo del título (px)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 48
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Cuerpo del texto",
      "default": "<p>Escribe aquí una descripción de tu sitio o marca. Puedes contar tu historia, tus valores o lo que te diferencia del resto.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del cuerpo",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del cuerpo (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Botón (opcional)"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "URL del botón"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Fondo del botón",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Color del texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL del video (mp4, webm…)",
      "info": "Pega el enlace directo al archivo de video. Si usas Shopify Files, sube el video y copia la URL."
    },
    {
      "type": "range",
      "id": "video_max_width",
      "label": "Ancho máximo del video (px)",
      "min": 160,
      "max": 900,
      "step": 20,
      "default": 560
    },
    {
      "type": "range",
      "id": "video_radius",
      "label": "Radio de bordes del video (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Texto y Video"
    }
  ]
}
{% endschema %}
