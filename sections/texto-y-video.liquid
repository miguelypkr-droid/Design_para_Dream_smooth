<div class="tyv-section" style="background: {{ section.settings.bg_color }};">
  <div class="tyv-dots-layer"></div>
  <div class="tyv-inner">

    <!-- Columna izquierda: texto -->
    <div class="tyv-text-col">
      {%- if section.settings.eyebrow != blank -%}
        <p class="tyv-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="tyv-heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="tyv-body" style="color: {{ section.settings.text_color }};">
          {{ section.settings.body }}
        </div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
        <a href="{{ section.settings.btn_url }}" class="tyv-btn"
           style="background: {{ section.settings.btn_bg }}; color: {{ section.settings.btn_color }};">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>

    <!-- Columna derecha: video -->
    <div class="tyv-video-col">
      {%- if section.settings.video_url != blank -%}
        <div class="tyv-video-wrap" style="border-radius: {{ section.settings.video_radius }}px;">
          <video
            src="{{ section.settings.video_url }}"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablePictureInPicture
            controlsList="nodownload nofullscreen noremoteplayback noplaybackrate"
            style="pointer-events: none;"
          ></video>
          <div class="tyv-stamp"><span>Prenda</span><span>trend</span></div>
        </div>
      {%- elsif section.settings.video_shopify != blank -%}
        <div class="tyv-video-wrap" style="border-radius: {{ section.settings.video_radius }}px;">
          <video
            src="{{ section.settings.video_shopify }}"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablePictureInPicture
            controlsList="nodownload nofullscreen noremoteplayback noplaybackrate"
            style="pointer-events: none;"
          ></video>
          <div class="tyv-stamp"><span>Prenda</span><span>trend</span></div>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  @keyframes tyv-twinkle {
    0%,100% { opacity: 0.10; transform: scale(0.8); }
    30%     { opacity: 1;    transform: scale(1.5); }
    60%     { opacity: 0.45; transform: scale(1);   }
  }

  .tyv-section {
    width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  .tyv-dots-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .tyv-inner {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    flex-wrap: wrap;
  }

  /* ---- Animaciones de entrada ---- */
  @keyframes tyv-fade-left {
    from { opacity: 0; transform: translateX(-48px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes tyv-fade-right {
    from { opacity: 0; transform: translateX(48px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Columna texto ---- */
  .tyv-text-col {
    flex: 1 1 320px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    opacity: 0;
    {%- if section.settings.text_align == 'center' -%}
    align-items: center;
    text-align: center;
    {%- elsif section.settings.text_align == 'right' -%}
    align-items: flex-end;
    text-align: right;
    {%- else -%}
    align-items: flex-start;
    text-align: left;
    {%- endif -%}
  }

  .tyv-inner.tyv-visible .tyv-text-col {
    animation: tyv-fade-left 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  /* Columna video ---- */
  .tyv-video-col {
    flex: 1 1 320px;
    display: flex;
    justify-content: center;
    opacity: 0;
  }

  .tyv-inner.tyv-visible .tyv-video-col {
    animation: tyv-fade-right 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  .tyv-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0;
  }

  .tyv-heading {
    font-size: clamp(1.6rem, 3.5vw, {{ section.settings.heading_size }}px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
  }

  .tyv-body {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    margin: 0;
    max-width: 520px;
  }

  .tyv-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 0.4rem;
  }

  .tyv-btn:hover { opacity: 0.78; }

  /* ---- Columna video ---- */
  .tyv-video-col {

  .tyv-video-wrap {
    width: 100%;
    max-width: {{ section.settings.video_max_width }}px;
    overflow: visible;
    line-height: 0;
    position: relative;
  }

  /* ---- Sello Prenda trend ---- */
  .tyv-stamp {
    position: absolute;
    top: -1.2rem;
    right: -1.6rem;
    z-index: 3;
    background: rgba(22, 130, 50, 0.93);
    color: #fff;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    border: 2.5px solid rgba(255,255,255,0.75);
    box-shadow: inset 0 0 0 1px rgba(22,130,50,0.5), 2px 3px 12px rgba(0,0,0,0.45);
    transform: rotate(22deg);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.25;
    pointer-events: none;
    user-select: none;
    gap: 0.05rem;
  }
  .tyv-stamp span:first-child {
    font-size: 0.78rem;
    opacity: 0.88;
  }
  .tyv-stamp span:last-child {
    font-size: 1.05rem;
  }

  .tyv-video-wrap video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Capa invisible que bloquea clicks sobre el video (impide menú contextual) */
  .tyv-video-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: all;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .tyv-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .tyv-video-col { width: 100%; }
    .tyv-text-col  { width: 100%; }
  }
</style>

<script>
  (function () {
    /* ---- Animaciones de entrada con IntersectionObserver ---- */
    function initAnimations() {
      var inner = document.querySelector('.tyv-inner');
      if (!inner) return;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            inner.classList.add('tyv-visible');
            observer.disconnect();
          }
        });
      }, { threshold: 0.12 });
      observer.observe(inner);
    }

    /* ---- Bucle de video reforzado por JS ---- */
    function ensureLoop() {
      document.querySelectorAll('.tyv-video-wrap video').forEach(function (v) {
        v.loop = true;
        /* timeupdate: reinicia 0.25s antes del final para evitar el flash de pantalla negra */
        v.addEventListener('timeupdate', function () {
          if (v.duration && v.currentTime >= v.duration - 0.25) {
            v.currentTime = 0;
          }
        });
        v.addEventListener('ended', function () {
          v.currentTime = 0;
          v.play().catch(function () {});
        });
      });
    }

    function init() { initAnimations(); ensureLoop(); }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();

  (function () {
    function spawnDots() {
      var layer = document.querySelector('.tyv-dots-layer');
      if (!layer) return;
      var total = 50;
      for (var i = 0; i < total; i++) {
        var dot = document.createElement('span');
        var size = 2 + Math.random() * 5;
        dot.style.cssText = [
          'position:absolute',
          'border-radius:50%',
          'background:rgba(255,255,255,' + (0.3 + Math.random() * 0.7) + ')',
          'width:' + size + 'px',
          'height:' + size + 'px',
          'left:' + (Math.random() * 99) + '%',
          'top:' + (Math.random() * 99) + '%',
          'pointer-events:none',
          'animation:tyv-twinkle ' + (1.5 + Math.random() * 3.5) + 's ease-in-out ' + (Math.random() * 5) + 's infinite'
        ].join(';');
        layer.appendChild(dot);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', spawnDots);
    } else {
      spawnDots();
    }
  })();

  (function () {
    function spawnAsteroids() {
      var section = document.querySelector('.tyv-section');
      if (!section) return;

      var rocks = [
        {
          id: 'r1', size: 26,
          clip: 'polygon(28% 0%,72% 4%,96% 28%,100% 68%,78% 96%,38% 100%,8% 82%,0% 42%)',
          from: 'translate(-90px,15vh)',  to: 'translate(calc(100vw + 100px),58vh)',
          spin: 420,  dur: 9,  delay: 0
        },
        {
          id: 'r2', size: 18,
          clip: 'polygon(50% 0%,88% 14%,100% 52%,82% 90%,48% 100%,12% 88%,0% 50%,18% 12%)',
          from: 'translate(38vw,-90px)',  to: 'translate(72vw,calc(100vh + 100px))',
          spin: -360, dur: 11, delay: 2.5
        },
        {
          id: 'r3', size: 32,
          clip: 'polygon(22% 5%,62% 0%,94% 24%,100% 62%,80% 96%,44% 100%,10% 86%,0% 52%,6% 22%)',
          from: 'translate(calc(100vw + 90px),28vh)', to: 'translate(-110px,72vh)',
          spin: -520, dur: 13, delay: 5
        },
        {
          id: 'r4', size: 20,
          clip: 'polygon(42% 0%,80% 8%,100% 42%,90% 80%,60% 100%,20% 98%,0% 68%,6% 28%)',
          from: 'translate(-90px,68vh)',  to: 'translate(calc(100vw + 100px),18vh)',
          spin: 300,  dur: 8,  delay: 1.5
        },
        {
          id: 'r5', size: 22,
          clip: 'polygon(55% 0%,92% 18%,100% 58%,76% 94%,38% 100%,6% 76%,0% 36%,26% 4%)',
          from: 'translate(82vw,-90px)',  to: 'translate(-90px,calc(100vh + 90px))',
          spin: 480,  dur: 10, delay: 7
        },
        {
          id: 'r6', size: 15,
          clip: 'polygon(34% 0%,72% 2%,100% 36%,96% 72%,66% 100%,24% 100%,0% 64%,4% 26%)',
          from: 'translate(-80px,44vh)',  to: 'translate(calc(100vw + 80px),8vh)',
          spin: -280, dur: 12, delay: 3.8
        },
        {
          id: 'r7', size: 28,
          clip: 'polygon(46% 2%,84% 10%,100% 48%,88% 86%,52% 100%,14% 92%,0% 54%,10% 16%)',
          from: 'translate(54vw,calc(100vh + 90px))', to: 'translate(8vw,-110px)',
          spin: 400,  dur: 14, delay: 4.5
        }
      ];

      /* inyectar keyframes dinámicos */
      var styleEl = document.createElement('style');
      styleEl.textContent = rocks.map(function (r) {
        return '@keyframes tyv-rock-' + r.id + '{' +
          '0%{transform:' + r.from + ' rotate(0deg);opacity:0}' +
          '7%{opacity:0.88}' +
          '90%{opacity:0.82}' +
          '100%{transform:' + r.to + ' rotate(' + r.spin + 'deg);opacity:0}}';
      }).join('');
      document.head.appendChild(styleEl);

      rocks.forEach(function (r) {
        var el = document.createElement('div');
        el.style.cssText = [
          'position:absolute',
          'top:0',
          'left:0',
          'width:' + r.size + 'px',
          'height:' + r.size + 'px',
          'background:rgba(225,225,232,0.86)',
          'clip-path:' + r.clip,
          'box-shadow:0 0 6px 2px rgba(255,255,255,0.35)',
          'pointer-events:none',
          'z-index:0',
          'will-change:transform,opacity',
          'animation:tyv-rock-' + r.id + ' ' + r.dur + 's linear ' + r.delay + 's infinite'
        ].join(';');
        section.appendChild(el);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', spawnAsteroids);
    } else {
      spawnAsteroids();
    }
  })();
</script>

{% schema %}
{
  "name": "Texto y Video",
  "settings": [
    {
      "type": "header",
      "content": "Diseño general"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Relleno vertical (px)",
      "min": 0,
      "max": 160,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Ancho máximo del contenido (px)",
      "min": 600,
      "max": 1600,
      "step": 40,
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre columnas (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación del texto",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior (eyebrow)",
      "default": "Sobre nosotros"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color eyebrow",
      "default": "#888888"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Quiénes somos"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño máximo del título (px)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 48
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Cuerpo del texto",
      "default": "<p>Escribe aquí una descripción de tu sitio o marca. Puedes contar tu historia, tus valores o lo que te diferencia del resto.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del cuerpo",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del cuerpo (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "header",
      "content": "Botón (opcional)"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "URL del botón"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Fondo del botón",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Color del texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL del video (mp4, webm…)",
      "info": "Pega el enlace directo al archivo de video. Si usas Shopify Files, sube el video y copia la URL."
    },
    {
      "type": "range",
      "id": "video_max_width",
      "label": "Ancho máximo del video (px)",
      "min": 160,
      "max": 900,
      "step": 20,
      "default": 560
    },
    {
      "type": "range",
      "id": "video_radius",
      "label": "Radio de bordes del video (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Texto y Video"
    }
  ]
}
{% endschema %}
