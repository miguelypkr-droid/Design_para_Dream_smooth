
<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- comment -%} Barra superior "Colecciones" {%- endcomment -%}
  <div class="tres-colecciones__bar color-{{ section.settings.bar_color_scheme }}">
    <span class="tres-colecciones__bar-text">{{ section.settings.bar_text }}</span>
  </div>

  {%- comment -%} Grilla de 3 colecciones {%- endcomment -%}
  <div class="tres-colecciones__grid">
    {%- for i in (1..3) -%}
      {%- liquid
        case i
          when 1
            assign col = section.settings.collection_1
          when 2
            assign col = section.settings.collection_2
          when 3
            assign col = section.settings.collection_3
        endcase
      -%}

      <div class="tres-colecciones__item">
        <a
          class="tres-colecciones__link"
          {% unless col == blank %}href="{{ col.url }}"{% endunless %}
        >
          <div class="tres-colecciones__image-wrap">
            {%- if col != blank and col.image != blank -%}
              {{
                col.image
                | image_url: width: 800
                | image_tag:
                  width: col.image.width,
                  height: col.image.height,
                  alt: col.image.alt | default: col.title,
                  class: 'tres-colecciones__img',
                  widths: '400, 600, 800',
                  sizes: '(min-width: 750px) 33vw, 100vw'
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'tres-colecciones__placeholder' }}
            {%- endif -%}
          </div>

          <div class="tres-colecciones__info">
            <span class="tres-colecciones__title">
              {%- if col != blank -%}
                {{ col.title }}
              {%- else -%}
                {{ 'onboarding.collection_title' | t }}
              {%- endif -%}
            </span>
          </div>
        </a>
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .tres-colecciones__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    margin-bottom: 24px;
    background-color: currentColor;
  }

  .tres-colecciones__bar.color-scheme-1 {
    background-color: rgb(var(--color-base-accent-1));
    color: rgb(var(--color-base-solid-button-labels));
  }

  .tres-colecciones__bar-text {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: inherit;
  }

  .tres-colecciones__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media screen and (max-width: 749px) {
    .tres-colecciones__grid {
      grid-template-columns: 1fr;
    }
  }

  .tres-colecciones__item {
    position: relative;
  }

  .tres-colecciones__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .tres-colecciones__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border-radius: var(--media-radius, 0px);
  }

  .tres-colecciones__img,
  .tres-colecciones__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .tres-colecciones__link:hover .tres-colecciones__img,
  .tres-colecciones__link:hover .tres-colecciones__placeholder {
    transform: scale(1.04);
  }

  .tres-colecciones__info {
    margin-top: 12px;
    text-align: center;
  }

  .tres-colecciones__title {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
</style>

{% schema %}
{
  "name": "Tres colecciones",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "bar_text",
      "label": "Texto de la barra",
      "default": "Colecciones"
    },
    {
      "type": "color_scheme",
      "id": "bar_color_scheme",
      "label": "Color de la barra",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Colecciones"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Colección 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Colección 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Colección 3"
    },
    {
      "type": "header",
      "content": "Diseño de sección"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho de la sección",
      "options": [
        { "value": "full-width", "label": "Completo" },
        { "value": "page-width", "label": "Página" },
        { "value": "narrow", "label": "Angosto" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color de la sección",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacio superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacio inferior",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Tres colecciones"
    }
  ]
}
{% endschema %}
