<div
  class="section section--{{ section.settings.section_width }} spacing-style ctabs__section"
  style="background: {{ section.settings.bg_color }}; position: relative; overflow: hidden; {% render 'spacing-style', settings: section.settings %}"
>
  <canvas class="ctabs__starfield" aria-hidden="true"></canvas>

  {%- comment -%} Título opcional {%- endcomment -%}
  {%- if section.settings.title != blank -%}
    <h2 class="ctabs__heading">{{ section.settings.title }}</h2>
  {%- endif -%}

  {%- comment -%} Barra de tabs {%- endcomment -%}
  <div class="ctabs__tabbar" role="tablist">
    {%- for i in (1..3) -%}
      {%- liquid
        case i
          when 1
            assign col = section.settings.collection_1
          when 2
            assign col = section.settings.collection_2
          when 3
            assign col = section.settings.collection_3
        endcase
      -%}
      {%- if col != blank -%}
        <button
          class="ctabs__tab{% if i == 1 %} ctabs__tab--active{% endif %}"
          role="tab"
          aria-selected="{% if i == 1 %}true{% else %}false{% endif %}"
          data-tab="{{ i }}"
          aria-controls="ctabs-panel-{{ section.id }}-{{ i }}"
        >
          {{ col.title }}
        </button>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Paneles de productos {%- endcomment -%}
  {%- for i in (1..3) -%}
    {%- liquid
      case i
        when 1
          assign col = section.settings.collection_1
        when 2
          assign col = section.settings.collection_2
        when 3
          assign col = section.settings.collection_3
      endcase
    -%}
    {%- if col != blank -%}
      <div
        class="ctabs__panel{% if i == 1 %} ctabs__panel--active{% endif %}"
        id="ctabs-panel-{{ section.id }}-{{ i }}"
        role="tabpanel"
        data-panel="{{ i }}"
      >
        <div class="ctabs__grid">
          {%- assign limit = section.settings.products_per_collection -%}
          {%- for product in col.products limit: limit -%}
            <a class="ctabs__card" href="{{ product.url }}">
              <div class="ctabs__card-img-wrap">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      class: 'ctabs__card-img',
                      alt: product.title,
                      loading: 'lazy',
                      widths: '300,400,600'
                  }}
                {%- else -%}
                  <div class="ctabs__card-img-placeholder">
                    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
                      <rect width="40" height="40" rx="4" fill="rgba(255,255,255,0.05)"/>
                      <path d="M10 30l8-10 6 7 4-5 8 8H10z" fill="rgba(255,255,255,0.1)"/>
                    </svg>
                  </div>
                {%- endif -%}
                {%- if product.compare_at_price > product.price -%}
                  <span class="ctabs__badge">SALE</span>
                {%- endif -%}
              </div>
              <div class="ctabs__card-body">
                <p class="ctabs__card-vendor">{{ product.vendor }}</p>
                <p class="ctabs__card-title">{{ product.title }}</p>
                <div class="ctabs__card-price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="ctabs__price ctabs__price--sale">{{ product.price | money }}</span>
                    <span class="ctabs__price ctabs__price--compare">{{ product.compare_at_price | money }}</span>
                  {%- else -%}
                    <span class="ctabs__price">{{ product.price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- else -%}
            <p class="ctabs__empty">Esta colección no tiene productos.</p>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

<style>
  .ctabs__section {
    padding-top: 0 !important;
  }

  .ctabs__starfield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  .ctabs__heading {
    position: relative;
    z-index: 1;
    text-align: center;
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 28px;
    padding-top: 40px;
  }

  /* ── Barra de tabs ───────────────────────────────────────────────── */
  .ctabs__tabbar {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    gap: 0;
    background: #1c1c1e;
    width: 100vw;
    left: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-bottom: 32px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ctabs__tabbar::-webkit-scrollbar { display: none; }

  .ctabs__tab {
    flex-shrink: 0;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    color: rgba(255,255,255,0.45);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 16px 28px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .ctabs__tab:hover {
    color: rgba(255,255,255,0.8);
  }
  .ctabs__tab--active {
    color: #ffffff;
    border-bottom-color: #ffffff;
  }

  /* ── Panel ────────────────────────────────────────────────────────── */
  .ctabs__panel {
    display: none;
    position: relative;
    z-index: 1;
  }
  .ctabs__panel--active {
    display: block;
  }

  /* ── Grid de productos ────────────────────────────────────────────── */
  .ctabs__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding-bottom: 40px;
  }

  @media screen and (max-width: 989px) {
    .ctabs__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
  }
  @media screen and (max-width: 749px) {
    .ctabs__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .ctabs__tab {
      padding: 14px 18px;
      font-size: 0.8rem;
    }
  }
  @media screen and (max-width: 420px) {
    .ctabs__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }

  /* ── Tarjeta de producto ─────────────────────────────────────────── */
  .ctabs__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #1c1c1e;
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .ctabs__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.55);
  }

  .ctabs__card-img-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
  }
  .ctabs__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .ctabs__card:hover .ctabs__card-img {
    transform: scale(1.05);
  }
  .ctabs__card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ctabs__card-img-placeholder svg {
    width: 60%;
    height: 60%;
  }

  .ctabs__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #fff;
    color: #000;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .ctabs__card-body {
    padding: 12px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .ctabs__card-vendor {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }
  .ctabs__card-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ctabs__card-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 4px;
  }
  .ctabs__price {
    font-size: 0.9rem;
    font-weight: 700;
    color: #ffffff;
  }
  .ctabs__price--sale {
    color: #ffffff;
  }
  .ctabs__price--compare {
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255,255,255,0.35);
    text-decoration: line-through;
  }

  .ctabs__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 0.88rem;
    padding: 40px 0;
  }
</style>

<script>
(function () {
  /* ── Starfield ─────────────────────────────────────────────────────── */
  function initStarfield(section) {
    var canvas = section.querySelector('.ctabs__starfield');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var stars = [];
    var raf;

    function buildStars() {
      canvas.width  = section.offsetWidth  || 1200;
      canvas.height = section.offsetHeight || 600;
      stars = [];
      for (var i = 0; i < 140; i++) {
        stars.push({
          x:     Math.random() * canvas.width,
          y:     Math.random() * canvas.height,
          r:     Math.random() * 1.4 + 0.3,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.012 + 0.004
        });
      }
    }

    function draw(t) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var time = t * 0.001;
      for (var i = 0; i < stars.length; i++) {
        var s = stars[i];
        var opacity = 0.12 + 0.78 * (0.5 + 0.5 * Math.sin(time * s.speed * 60 + s.phase));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, 6.2832);
        ctx.fillStyle = 'rgba(255,255,255,' + opacity.toFixed(3) + ')';
        ctx.fill();
      }
      raf = requestAnimationFrame(draw);
    }

    buildStars();
    raf = requestAnimationFrame(draw);

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        cancelAnimationFrame(raf);
        buildStars();
        raf = requestAnimationFrame(draw);
      }, 150);
    });
  }

  document.querySelectorAll('.ctabs__starfield').forEach(function (canvas) {
    initStarfield(canvas.closest('.ctabs__section'));
  });

  /* ── Tabs ──────────────────────────────────────────────────────────── */
  document.querySelectorAll('.ctabs__tabbar').forEach(function (tabbar) {
    var section = tabbar.closest('.ctabs__section');
    if (!section) return;

    tabbar.querySelectorAll('.ctabs__tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var idx = tab.getAttribute('data-tab');

        // Actualizar tabs
        tabbar.querySelectorAll('.ctabs__tab').forEach(function (t) {
          t.classList.remove('ctabs__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('ctabs__tab--active');
        tab.setAttribute('aria-selected', 'true');

        // Actualizar paneles
        section.querySelectorAll('.ctabs__panel').forEach(function (panel) {
          if (panel.getAttribute('data-panel') === idx) {
            panel.classList.add('ctabs__panel--active');
          } else {
            panel.classList.remove('ctabs__panel--active');
          }
        });
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Colecciones con Tabs",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Nuestros Productos"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#000000"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Colección 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Colección 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Colección 3"
    },
    {
      "type": "range",
      "id": "products_per_collection",
      "label": "Productos por colección",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Ancho",
      "options": [
        { "value": "page-width", "label": "Página" },
        { "value": "full-width", "label": "Completo" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Espacio superior",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Espacio inferior",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Colecciones con Tabs"
    }
  ]
}
{% endschema %}
