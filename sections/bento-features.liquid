<div class="bento-features" style="background-color: {{ section.settings.background_color }};">
  <canvas class="bento-features__starfield" aria-hidden="true"></canvas>
  <div class="bento-features__grid">

    <!-- ── Tarjeta 1: Grande izquierda ── -->
    <div class="bento-card bento-card--large">

      <div class="bento-card__text">
        {%- if section.settings.card1_heading != blank -%}
          <h2 class="bento-card__heading">{{ section.settings.card1_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.card1_text != blank -%}
          <p class="bento-card__subtext">{{ section.settings.card1_text }}</p>
        {%- endif -%}
      </div>

      <!-- Collage de imágenes -->
      <div class="bento-collage">
        {%- if section.settings.card1_image1 != blank -%}
          <div class="bento-collage__item bento-collage__item--1">
            {{ section.settings.card1_image1 | image_url: width: 500 | image_tag: class: 'bento-collage__img', loading: 'lazy', alt: section.settings.card1_heading }}
            {%- if section.settings.card1_label2 != blank -%}
              <span class="bento-badge">● {{ section.settings.card1_label2 }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.card1_image2 != blank -%}
          <div class="bento-collage__item bento-collage__item--2">
            {{ section.settings.card1_image2 | image_url: width: 500 | image_tag: class: 'bento-collage__img', loading: 'lazy', alt: section.settings.card1_heading }}
            {%- if section.settings.card1_label3 != blank -%}
              <span class="bento-badge">● {{ section.settings.card1_label3 }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.card1_image3 != blank -%}
          <div class="bento-collage__item bento-collage__item--3">
            {{ section.settings.card1_image3 | image_url: width: 320 | image_tag: class: 'bento-collage__img', loading: 'lazy', alt: section.settings.card1_heading }}
          </div>
        {%- endif -%}
      </div>

      <!-- Notificación flotante -->
      {%- if section.settings.card1_notif_text != blank -%}
        <div class="bento-notif">
          {%- if section.settings.card1_notif_icon != blank -%}
            {{ section.settings.card1_notif_icon | image_url: width: 80 | image_tag: class: 'bento-notif__icon', loading: 'lazy', alt: section.settings.card1_notif_app }}
          {%- else -%}
            <div class="bento-notif__icon bento-notif__icon--placeholder"></div>
          {%- endif -%}
          <div class="bento-notif__body">
            <span class="bento-notif__app">{{ section.settings.card1_notif_app }}</span>
            <span class="bento-notif__msg">{{ section.settings.card1_notif_text }}</span>
          </div>
          {%- if section.settings.card1_notif_time != blank -%}
            <span class="bento-notif__time">{{ section.settings.card1_notif_time }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <!-- Etiqueta ciudad inferior -->
      {%- if section.settings.card1_label1 != blank -%}
        <span class="bento-badge bento-badge--abs-bottom">● {{ section.settings.card1_label1 }}</span>
      {%- endif -%}

    </div><!-- /card 1 -->

    <!-- ── Columna derecha ── -->
    <div class="bento-features__right">

      <!-- Tarjeta 2: Grande superior derecha -->
      <div class="bento-card bento-card--top-right">
        <div class="bento-card__text">
          {%- if section.settings.card2_heading != blank -%}
            <h2 class="bento-card__heading">{{ section.settings.card2_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.card2_text != blank -%}
            <p class="bento-card__subtext">{{ section.settings.card2_text }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.card2_image != blank -%}
          <div class="bento-card__media bento-card__media--float">
            {{ section.settings.card2_image | image_url: width: 420 | image_tag: class: 'bento-card__img', loading: 'lazy', alt: section.settings.card2_heading }}
          </div>
        {%- endif -%}
      </div>

      <!-- Fila inferior: 2 tarjetas pequeñas -->
      <div class="bento-features__bottom-row">

        <!-- Tarjeta 3 -->
        <div class="bento-card bento-card--small">
          <div class="bento-card__text">
            {%- if section.settings.card3_heading != blank -%}
              <h2 class="bento-card__heading">{{ section.settings.card3_heading }}</h2>
            {%- endif -%}
            {%- if section.settings.card3_text != blank -%}
              <p class="bento-card__subtext">{{ section.settings.card3_text }}</p>
            {%- endif -%}
          </div>
          {%- if section.settings.card3_image != blank -%}
            <div class="bento-card__media">
              {{ section.settings.card3_image | image_url: width: 360 | image_tag: class: 'bento-card__img', loading: 'lazy', alt: section.settings.card3_heading }}
            </div>
          {%- endif -%}
        </div>

        <!-- Tarjeta 4 -->
        <div class="bento-card bento-card--small">
          <div class="bento-card__text">
            {%- if section.settings.card4_heading != blank -%}
              <h2 class="bento-card__heading">{{ section.settings.card4_heading }}</h2>
            {%- endif -%}
            {%- if section.settings.card4_text != blank -%}
              <p class="bento-card__subtext">{{ section.settings.card4_text }}</p>
            {%- endif -%}
          </div>
          {%- if section.settings.card4_image != blank -%}
            <div class="bento-card__media">
              {{ section.settings.card4_image | image_url: width: 360 | image_tag: class: 'bento-card__img', loading: 'lazy', alt: section.settings.card4_heading }}
            </div>
          {%- endif -%}
        </div>

      </div><!-- /bottom row -->
    </div><!-- /right column -->

  </div><!-- /grid -->
</div><!-- /bento-features -->

{% stylesheet %}

/* ─────────────── WRAPPER ─────────────── */
.bento-features {
  width: 100%;
  padding: 2.5rem 1.5rem;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.bento-features__starfield {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
  display: block;
}

.bento-features__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

/* ─────────────── TARJETA BASE ─────────────── */
.bento-card {
  background: #1c1c1e;
  border-radius: 22px;
  padding: 1.75rem;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  color: #ffffff;
}

.bento-card__heading {
  font-size: clamp(1.5rem, 2.8vw, 2.3rem);
  font-weight: 700;
  line-height: 1.15;
  margin: 0 0 0.4rem 0;
  color: #ffffff;
}

.bento-card__subtext {
  font-size: 0.92rem;
  color: #9a9a9a;
  margin: 0;
  line-height: 1.55;
  max-width: 26ch;
}

/* ─────────────── TARJETA GRANDE (izquierda) ─────────────── */
.bento-card--large {
  min-height: 540px;
  display: flex;
  flex-direction: column;
}

/* Collage */
.bento-collage {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.bento-collage__item {
  position: absolute;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.55);
}

.bento-collage__item--1 {
  top: 28%;
  right: 5%;
  width: 46%;
  height: 38%;
}

.bento-collage__item--2 {
  bottom: 8%;
  right: 28%;
  width: 46%;
  height: 38%;
}

.bento-collage__item--3 {
  bottom: 12%;
  right: 5%;
  width: 32%;
  height: 28%;
  transform: rotate(2deg);
  z-index: 2;
}

.bento-collage__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Badge de ciudad */
.bento-badge {
  position: absolute;
  bottom: 0.45rem;
  left: 0.6rem;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  padding: 0.22em 0.65em;
  border-radius: 20px;
  white-space: nowrap;
}

.bento-badge--abs-bottom {
  position: absolute;
  bottom: 1.4rem;
  left: 1.75rem;
}

/* Notificación flotante */
.bento-notif {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  background: rgba(255, 255, 255, 0.09);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 16px;
  padding: 0.65rem 0.9rem;
  position: absolute;
  bottom: 3.8rem;
  left: 1.75rem;
  max-width: 56%;
  z-index: 10;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
}

.bento-notif__icon {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  object-fit: cover;
  flex-shrink: 0;
}

.bento-notif__icon--placeholder {
  background: linear-gradient(135deg, #444, #222);
  display: block;
}

.bento-notif__body {
  display: flex;
  flex-direction: column;
  gap: 0.08rem;
  min-width: 0;
}

.bento-notif__app {
  font-size: 0.75rem;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
}

.bento-notif__msg {
  font-size: 0.72rem;
  color: #cccccc;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bento-notif__time {
  font-size: 0.63rem;
  color: #777;
  margin-left: auto;
  flex-shrink: 0;
  align-self: flex-start;
  padding-top: 0.1rem;
}

/* ─────────────── COLUMNA DERECHA ─────────────── */
.bento-features__right {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* Tarjeta grande superior derecha */
.bento-card--top-right {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  min-height: 240px;
  overflow: hidden;
}

/* Imágenes en las tarjetas */
.bento-card__media {
  flex-shrink: 0;
  max-width: 50%;
  display: flex;
  align-items: flex-end;
  align-self: stretch;
}

.bento-card__media--float {
  align-items: center;
  overflow: visible;
}

.bento-card__img {
  width: 100%;
  height: auto;
  object-fit: contain;
  display: block;
  border-radius: 10px;
  max-height: 100%;
}

/* Fila inferior: 2 tarjetas pequeñas */
.bento-features__bottom-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.bento-card--small {
  min-height: 200px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.bento-card--small .bento-card__media {
  max-width: 100%;
  margin-top: 0.75rem;
  align-self: flex-end;
}

.bento-card--small .bento-card__img {
  border-radius: 8px;
}

/* ─────────────── RESPONSIVE ─────────────── */
@media screen and (max-width: 900px) {
  .bento-features__grid {
    grid-template-columns: 1fr;
  }

  .bento-card--large {
    min-height: 420px;
  }

  .bento-card--top-right {
    min-height: 200px;
  }
}

@media screen and (max-width: 480px) {
  .bento-features {
    padding: 1rem;
  }

  .bento-features__bottom-row {
    grid-template-columns: 1fr;
  }

  .bento-card--small {
    min-height: 160px;
  }

  .bento-card__heading {
    font-size: 1.4rem;
  }
}

/* ─────────────── ANIMACIONES DE APARICIÓN ─────────────── */
.bento-card {
  opacity: 0;
  transform: translateY(36px);
  transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
}

.bento-card.bento-anim--visible {
  opacity: 1;
  transform: translateY(0);
}

{% endstylesheet %}

<script>
(function () {
  function initBentoStarfield(section) {
    var canvas = section.querySelector('.bento-features__starfield');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var stars = [];
    var raf;

    function buildStars() {
      canvas.width  = section.offsetWidth  || 1200;
      canvas.height = section.offsetHeight || 600;
      stars = [];
      for (var i = 0; i < 160; i++) {
        stars.push({
          x:     Math.random() * canvas.width,
          y:     Math.random() * canvas.height,
          r:     Math.random() * 1.4 + 0.3,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.012 + 0.004
        });
      }
    }

    function draw(t) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var time = t * 0.001;
      for (var i = 0; i < stars.length; i++) {
        var s = stars[i];
        var opacity = 0.12 + 0.7 * (0.5 + 0.5 * Math.sin(time * s.speed * 60 + s.phase));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, 6.2832);
        ctx.fillStyle = 'rgba(255,255,255,' + opacity.toFixed(3) + ')';
        ctx.fill();
      }
      raf = requestAnimationFrame(draw);
    }

    buildStars();
    raf = requestAnimationFrame(draw);

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        cancelAnimationFrame(raf);
        buildStars();
        raf = requestAnimationFrame(draw);
      }, 150);
    });
  }

  document.querySelectorAll('.bento-features__starfield').forEach(function (canvas) {
    initBentoStarfield(canvas.closest('.bento-features'));
  });

  // Animaciones de aparición al hacer scroll
  if ('IntersectionObserver' in window) {
    var cardObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var delay = parseInt(entry.target.getAttribute('data-bento-delay') || '0', 10);
          setTimeout(function () {
            entry.target.classList.add('bento-anim--visible');
          }, delay);
          cardObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.bento-features .bento-card').forEach(function (card, i) {
      card.setAttribute('data-bento-delay', i * 130);
      cardObserver.observe(card);
    });
  } else {
    document.querySelectorAll('.bento-features .bento-card').forEach(function (card) {
      card.classList.add('bento-anim--visible');
    });
  }
})();
</script>

