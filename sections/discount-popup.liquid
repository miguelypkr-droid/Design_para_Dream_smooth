{% comment %} ── Discount Email Popup ── {% endcomment %}

{%- assign popup_delay = section.settings.delay | times: 1000 -%}

<div id="ds-popup-overlay" role="dialog" aria-modal="true" aria-labelledby="ds-popup-title" hidden>
  <div id="ds-popup-card">
    <canvas id="ds-stars-canvas" aria-hidden="true"></canvas>
    <button id="ds-popup-close" aria-label="Cerrar">&times;</button>

    {%- comment %} ── PASO 1: formulario ── {%- endcomment %}
    <div id="ds-popup-step1">
      <div class="ds-popup-icon" aria-hidden="true">🎁</div>
      <h2 id="ds-popup-title">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>

      <form id="ds-popup-form" novalidate>
        <label for="ds-popup-email" class="visually-hidden">Correo electrónico</label>
        <input
          id="ds-popup-email"
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder }}"
          autocomplete="email"
          required
        >
        <div id="ds-popup-error" role="alert" hidden></div>
        <button type="submit" id="ds-popup-submit">
          <span id="ds-popup-btn-label">{{ section.settings.button_text }}</span>
          <span id="ds-popup-spinner" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" opacity=".25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/></svg>
          </span>
        </button>
      </form>
      <p class="ds-popup-privacy">{{ section.settings.privacy_note }}</p>
    </div>

    {%- comment %} ── PASO 2: código de descuento ── {%- endcomment %}
    <div id="ds-popup-step2" hidden>
      <div class="ds-popup-icon" aria-hidden="true">✅</div>
      <h2>{{ section.settings.success_heading }}</h2>
      <p>{{ section.settings.success_text }}</p>
      <div class="ds-code-wrapper">
        <span id="ds-discount-code">{{ section.settings.discount_code }}</span>
        <button id="ds-copy-btn" aria-label="Copiar código">
          <svg id="ds-copy-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <svg id="ds-check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" hidden><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
      <p id="ds-copied-msg" hidden>¡Copiado!</p>
      <button id="ds-popup-step2-close" class="ds-btn-secondary">Cerrar</button>
    </div>
  </div>
</div>

<style>
  /* ── overlay ── */
  #ds-popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  #ds-popup-overlay[hidden] { display: none !important; }
  #ds-popup-overlay.ds-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── card ── */
  #ds-popup-card {
    position: relative;
    overflow: hidden;
    background: #000000;
    color: #e8e8f0;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 22px;
    padding: 44px 38px 34px;
    max-width: 430px;
    width: 100%;
    text-align: center;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.05), 0 32px 80px rgba(0,0,0,0.7);
    transform: translateY(28px) scale(0.96);
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s ease;
    opacity: 0;
  }
  #ds-popup-overlay.ds-visible #ds-popup-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* ── stars canvas ── */
  #ds-stars-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── all content above stars ── */
  #ds-popup-close,
  #ds-popup-step1,
  #ds-popup-step2 {
    position: relative;
    z-index: 1;
  }

  /* ── close btn ── */
  #ds-popup-close {
    position: absolute;
    top: 14px;
    right: 18px;
    background: transparent;
    border: none;
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    color: rgba(255,255,255,0.45);
    padding: 4px 8px;
    transition: color 0.15s;
    z-index: 2;
  }
  #ds-popup-close:hover { color: #fff; }

  /* ── icon ── */
  .ds-popup-icon {
    font-size: 42px;
    margin-bottom: 14px;
    filter: drop-shadow(0 0 8px rgba(255,220,100,0.6));
  }

  /* ── headings ── */
  #ds-popup-card h2 {
    font-size: clamp(1.1rem, 4vw, 1.45rem);
    font-weight: 700;
    margin: 0 0 10px;
    line-height: 1.3;
    color: #ffffff;
    text-shadow: 0 0 18px rgba(255,255,255,0.25);
  }
  #ds-popup-card p {
    font-size: 0.92rem;
    color: rgba(220,220,235,0.75);
    margin: 0 0 20px;
    line-height: 1.6;
  }

  /* ── email input ── */
  #ds-popup-email {
    display: block;
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    font-size: 0.95rem;
    margin-bottom: 10px;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: rgba(255,255,255,0.07);
    color: #fff;
  }
  #ds-popup-email::placeholder { color: rgba(255,255,255,0.35); }
  #ds-popup-email:focus {
    border-color: rgba(255,255,255,0.5);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.08);
  }

  /* ── error ── */
  #ds-popup-error {
    color: #ff6b6b;
    font-size: 0.83rem;
    margin-bottom: 8px;
    text-align: left;
  }

  /* ── submit button ── */
  #ds-popup-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px;
    background: linear-gradient(135deg, #ffffff 0%, #d0d0e8 100%);
    color: #0a0a0f;
    border: none;
    border-radius: 10px;
    font-size: 0.97rem;
    font-weight: 700;
    cursor: pointer;
    transition: filter 0.2s, transform 0.15s, box-shadow 0.2s;
    letter-spacing: 0.04em;
    box-shadow: 0 0 18px rgba(255,255,255,0.15);
  }
  #ds-popup-submit:hover:not(:disabled) {
    filter: brightness(1.08);
    transform: scale(1.02);
    box-shadow: 0 0 28px rgba(255,255,255,0.3);
  }
  #ds-popup-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  /* spinner */
  @keyframes ds-spin { to { transform: rotate(360deg); } }
  #ds-popup-spinner svg { animation: ds-spin 0.8s linear infinite; }

  /* ── privacy note ── */
  .ds-popup-privacy {
    font-size: 0.76rem;
    margin: 12px 0 0;
    color: rgba(255,255,255,0.35);
  }

  /* ── code wrapper ── */
  .ds-code-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.06);
    border: 2px dashed rgba(255,255,255,0.3);
    border-radius: 12px;
    padding: 14px 22px;
    margin: 10px 0 20px;
  }
  #ds-discount-code {
    font-family: monospace;
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    color: #fff;
    text-shadow: 0 0 14px rgba(255,255,255,0.6);
    user-select: all;
  }
  #ds-copy-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgba(255,255,255,0.6);
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s, transform 0.15s;
  }
  #ds-copy-btn:hover { color: #fff; transform: scale(1.15); }

  #ds-copied-msg {
    color: #7fffb2;
    font-size: 0.85rem;
    font-weight: 600;
    margin: -12px 0 14px;
    text-shadow: 0 0 8px rgba(127,255,178,0.5);
  }

  /* ── secondary close btn ── */
  .ds-btn-secondary {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    padding: 9px 26px;
    font-size: 0.88rem;
    cursor: pointer;
    color: rgba(255,255,255,0.55);
    transition: color 0.15s, border-color 0.15s;
  }
  .ds-btn-secondary:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.55);
  }

  /* ── accessibility helper ── */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    #ds-popup-card { padding: 34px 20px 28px; }
  }
</style>

<script>
(function () {
  var STORAGE_KEY = 'ds_popup_done';
  var delay       = {{ popup_delay }};

  var overlay    = document.getElementById('ds-popup-overlay');
  var closeBtn   = document.getElementById('ds-popup-close');
  var form       = document.getElementById('ds-popup-form');
  var emailInput = document.getElementById('ds-popup-email');
  var submitBtn  = document.getElementById('ds-popup-submit');
  var btnLabel   = document.getElementById('ds-popup-btn-label');
  var spinner    = document.getElementById('ds-popup-spinner');
  var errorEl    = document.getElementById('ds-popup-error');
  var step1      = document.getElementById('ds-popup-step1');
  var step2      = document.getElementById('ds-popup-step2');
  var copyBtn    = document.getElementById('ds-copy-btn');
  var copyIcon   = document.getElementById('ds-copy-icon');
  var checkIcon  = document.getElementById('ds-check-icon');
  var copiedMsg  = document.getElementById('ds-copied-msg');
  var step2Close = document.getElementById('ds-popup-step2-close');
  var codeEl     = document.getElementById('ds-discount-code');

  // ── Don't show if already subscribed ──
  if (localStorage.getItem(STORAGE_KEY)) return;

  // ── Show popup after delay ──
  function openPopup() {
    overlay.hidden = false;
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        overlay.classList.add('ds-visible');
        emailInput.focus();
      });
    });
  }

  setTimeout(function () {
    // Slight extra wait if curtain animation is still playing
    var curtains = document.getElementById('pageCurtains');
    if (curtains && !curtains.classList.contains('curtains-done')) {
      curtains.addEventListener('transitionend', function onCurtainEnd() {
        curtains.removeEventListener('transitionend', onCurtainEnd);
        setTimeout(openPopup, 600);
      });
    } else {
      openPopup();
    }
  }, delay);

  // ── Close helpers ──
  function closePopup() {
    overlay.classList.remove('ds-visible');
    setTimeout(function () { overlay.hidden = true; }, 350);
  }

  closeBtn.addEventListener('click', closePopup);
  step2Close.addEventListener('click', closePopup);

  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !overlay.hidden) closePopup();
  });

  // ── Show error ──
  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.hidden = false;
  }
  function clearError() {
    errorEl.textContent = '';
    errorEl.hidden = true;
  }

  // ── Form submit ──
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    clearError();

    var email = emailInput.value.trim();
    if (!email) {
      showError('Por favor, ingresa tu correo.');
      emailInput.focus();
      return;
    }
    // Basic email format check
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('Por favor, ingresa un correo válido.');
      emailInput.focus();
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    btnLabel.hidden    = true;
    spinner.hidden     = false;

    // POST to Shopify /contact (newsletter subscription)
    var formData = new FormData();
    formData.append('form_type', 'customer');
    formData.append('utf8', '✓');
    formData.append('contact[email]', email);
    formData.append('contact[tags]', 'newsletter,discount-popup');

    fetch('/contact', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: formData
    })
    .then(function (res) {
      // Shopify returns 200 for success and also for "already subscribed"
      if (res.ok || res.status === 422) {
        showStep2();
      } else {
        throw new Error('Error al enviar');
      }
    })
    .catch(function () {
      // Even on network error, show the code (don't block the user)
      showStep2();
    });
  });

  function showStep2() {
    localStorage.setItem(STORAGE_KEY, '1');
    step1.hidden = true;
    step2.hidden = false;
    submitBtn.disabled = false;
    btnLabel.hidden    = false;
    spinner.hidden     = true;
  }

  // ── Copy code ──
  copyBtn.addEventListener('click', function () {
    var code = codeEl.textContent.trim();
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(code).then(showCopied);
    } else {
      // Fallback for older browsers
      var ta = document.createElement('textarea');
      ta.value = code;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      try { document.execCommand('copy'); showCopied(); } catch(err) {}
      document.body.removeChild(ta);
    }
  });

  function showCopied() {
    copyIcon.hidden = true;
    checkIcon.hidden = false;
    copiedMsg.hidden = false;
    setTimeout(function () {
      copyIcon.hidden = false;
      checkIcon.hidden = true;
      copiedMsg.hidden = true;
    }, 2500);
  }

  // ── Twinkling stars ──
  (function () {
    var canvas = document.getElementById('ds-stars-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var stars = [];
    var raf;

    function resize() {
      var card = canvas.parentElement;
      canvas.width  = card.offsetWidth;
      canvas.height = card.offsetHeight;
    }

    function makeStars(n) {
      stars = [];
      for (var i = 0; i < n; i++) {
        stars.push({
          x:       Math.random() * canvas.width,
          y:       Math.random() * canvas.height,
          r:       Math.random() * 1.4 + 0.3,
          // each star has its own phase offset and speed
          phase:   Math.random() * Math.PI * 2,
          speed:   Math.random() * 0.6 + 0.3,
          baseAlpha: Math.random() * 0.5 + 0.2
        });
      }
    }

    function draw(ts) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var t = ts * 0.001;
      for (var i = 0; i < stars.length; i++) {
        var s = stars[i];
        // sine wave between 0 and baseAlpha
        var alpha = s.baseAlpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,' + alpha + ')';
        ctx.fill();
      }
      raf = requestAnimationFrame(draw);
    }

    function start() {
      resize();
      makeStars(80);
      raf = requestAnimationFrame(draw);
    }

    function stop() {
      if (raf) cancelAnimationFrame(raf);
    }

    // Start when popup opens, stop when hidden to save resources
    var origOpen  = openPopup;
    openPopup = function () { origOpen(); start(); };

    var origClose = closePopup;
    closePopup = function () {
      origClose();
      setTimeout(stop, 400);
    };

    window.addEventListener('resize', function () {
      resize();
      makeStars(80);
    });
  })();
})();
</script>

{% schema %}
{
  "name": "Popup Descuento",
  "limit": 1,
  "settings": [
    {
      "type": "range",
      "id": "delay",
      "label": "Retraso antes de mostrar (segundos)",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título del popup",
      "default": "¿Quieres un descuento del 5%?"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Texto descriptivo",
      "default": "Registra tu correo y obtén un código exclusivo para tu primera compra."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder del campo de correo",
      "default": "tu@correo.com"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Quiero mi descuento"
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Nota de privacidad",
      "default": "Sin spam. Puedes darte de baja en cualquier momento."
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Código de descuento",
      "default": "2026DREAM"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Título tras suscripción",
      "default": "¡Ya tienes tu código!"
    },
    {
      "type": "textarea",
      "id": "success_text",
      "label": "Texto tras suscripción",
      "default": "Copia el código y aplícalo en tu próxima compra para obtener el 5% de descuento."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento (botón / código)",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_text",
      "label": "Color del texto en el botón",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Color de fondo de la tarjeta",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text",
      "label": "Color del texto de la tarjeta",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Popup Descuento"
    }
  ]
}
{% endschema %}
