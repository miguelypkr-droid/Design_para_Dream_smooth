<div
  class="ir-section"
  data-ir-section
  style="position:relative;width:100%;overflow:hidden;background:#0a0a0a;"
>
  <div
    class="ir-wrapper"
    data-ir-wrapper
    style="
      position:relative;
      width:100%;
      max-width:{{ section.settings.max_width }}px;
      margin:0 auto;
      overflow:hidden;
      aspect-ratio:{{ section.settings.aspect_ratio }};
    "
  >

    <div class="ir-layer" style="position:absolute;inset:0;width:100%;height:100%;z-index:1;">
      {%- if section.settings.image_base != blank -%}
        <img
          src="{{ section.settings.image_base | image_url: width: 2000 }}"
          srcset="{{ section.settings.image_base | image_url: width: 600 }} 600w, {{ section.settings.image_base | image_url: width: 1200 }} 1200w, {{ section.settings.image_base | image_url: width: 2000 }} 2000w"
          sizes="100vw"
          alt="{{ section.settings.image_base.alt | escape }}"
          loading="eager"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;"
          draggable="false"
        >
      {%- else -%}
        <div style="position:absolute;inset:0;background:#1a1a2e;display:flex;align-items:center;justify-content:center;">
          <span style="color:rgba(255,255,255,0.2);font-size:0.9rem;letter-spacing:0.1em;font-family:sans-serif;">IMAGEN PRINCIPAL</span>
        </div>
      {%- endif -%}
    </div>

    <div
      data-ir-reveal
      style="position:absolute;inset:0;width:100%;height:100%;z-index:2;opacity:0;clip-path:circle(0px at -9999px -9999px);will-change:clip-path;"
    >
      {%- if section.settings.image_reveal != blank -%}
        <img
          src="{{ section.settings.image_reveal | image_url: width: 2000 }}"
          srcset="{{ section.settings.image_reveal | image_url: width: 600 }} 600w, {{ section.settings.image_reveal | image_url: width: 1200 }} 1200w, {{ section.settings.image_reveal | image_url: width: 2000 }} 2000w"
          sizes="100vw"
          alt="{{ section.settings.image_reveal.alt | escape }}"
          loading="eager"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;"
          draggable="false"
        >
      {%- else -%}
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,#e94560,#f5a623);display:flex;align-items:center;justify-content:center;">
          <span style="color:rgba(255,255,255,0.4);font-size:0.9rem;letter-spacing:0.1em;font-family:sans-serif;">IMAGEN REVELADA</span>
        </div>
      {%- endif -%}
    </div>

    <div
      data-ir-cursor
      style="position:absolute;top:0;left:0;z-index:10;pointer-events:none;opacity:0;will-change:transform;"
    >
      <div style="width:{{ section.settings.lens_size }}px;height:{{ section.settings.lens_size }}px;border-radius:50%;border:2px solid rgba(255,255,255,0.7);box-shadow:0 0 0 1px rgba(0,0,0,0.3);position:relative;transform:translate(-50%,-50%);">
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.9);"></div>
      </div>
    </div>

    {%- unless section.settings.hide_hint -%}
    <div data-ir-hint style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:15;pointer-events:none;text-align:center;">
      <div style="width:52px;height:52px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.5);display:flex;align-items:center;justify-content:center;margin:0 auto 8px;animation:ir-pulse 2.2s ease-in-out infinite;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <span style="font-family:sans-serif;font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);">{{ section.settings.hint_text | default: 'Pasa el cursor para revelar' }}</span>
    </div>
    {%- endunless -%}

    {%- if section.settings.label_text != blank -%}
    <div style="position:absolute;bottom:1.25rem;left:50%;transform:translateX(-50%);z-index:20;pointer-events:none;font-family:sans-serif;font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);background:rgba(0,0,0,0.35);padding:0.35rem 1rem;border-radius:100px;border:1px solid rgba(255,255,255,0.12);white-space:nowrap;">{{ section.settings.label_text }}</div>
    {%- endif -%}

  </div>
</div>

<style>
  @keyframes ir-pulse{0%,100%{transform:scale(1);opacity:.6}50%{transform:scale(1.2);opacity:1}}
  [data-ir-section]{-webkit-tap-highlight-color:transparent;}
  @media(hover:none){[data-ir-section]{cursor:default;}}
  @media(hover:hover){[data-ir-section]{cursor:none;}}
</style>

<script>
(function(){
  var section=document.currentScript.closest('[data-ir-section]');
  if(!section||section.dataset.irInit)return;
  section.dataset.irInit='1';
  var wrapper=section.querySelector('[data-ir-wrapper]');
  var reveal=section.querySelector('[data-ir-reveal]');
  var cursor=section.querySelector('[data-ir-cursor]');
  var hint=section.querySelector('[data-ir-hint]');
  if(!wrapper||!reveal)return;
  var lensSize={{ section.settings.lens_size | default: 200 }};
  var smoothing={{ section.settings.smoothing | default: 6 }};
  var half=lensSize/2;
  var tx=-9999,ty=-9999,cx=-9999,cy=-9999,active=false,raf=null;
  function draw(x,y){
    reveal.style.clipPath='circle('+half+'px at '+Math.round(x)+'px '+Math.round(y)+'px)';
    if(cursor)cursor.style.transform='translate('+Math.round(x)+'px,'+Math.round(y)+'px)';
  }
  function loop(){
    if(!active){raf=null;return;}
    cx+=(tx-cx)/smoothing;cy+=(ty-cy)/smoothing;
    draw(cx,cy);raf=requestAnimationFrame(loop);
  }
  function pos(clientX,clientY){var r=wrapper.getBoundingClientRect();return{x:clientX-r.left,y:clientY-r.top};}
  function show(clientX,clientY){
    active=true;reveal.style.opacity='1';
    if(cursor)cursor.style.opacity='1';if(hint)hint.style.opacity='0';
    var p=pos(clientX,clientY);tx=p.x;ty=p.y;
    if(!raf)raf=requestAnimationFrame(loop);
  }
  function hide(){
    active=false;reveal.style.opacity='0';
    if(cursor)cursor.style.opacity='0';if(hint)hint.style.opacity='1';
    reveal.style.clipPath='circle(0px at '+Math.round(cx)+'px '+Math.round(cy)+'px)';
    tx=-9999;ty=-9999;cx=-9999;cy=-9999;
    if(raf){cancelAnimationFrame(raf);raf=null;}
  }
  wrapper.addEventListener('mouseenter',function(e){show(e.clientX,e.clientY);});
  wrapper.addEventListener('mousemove',function(e){var p=pos(e.clientX,e.clientY);tx=p.x;ty=p.y;});
  wrapper.addEventListener('mouseleave',hide);
  wrapper.addEventListener('touchstart',function(e){if(e.touches.length)show(e.touches[0].clientX,e.touches[0].clientY);},{passive:true});
  wrapper.addEventListener('touchmove',function(e){e.preventDefault();if(e.touches.length){var p=pos(e.touches[0].clientX,e.touches[0].clientY);tx=p.x;ty=p.y;}},{passive:false});
  wrapper.addEventListener('touchend',hide);wrapper.addEventListener('touchcancel',hide);
})();
</script>

{% schema %}
{
  "name": "Image Reveal Lens",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Imágenes"
    },
    {
      "type": "image_picker",
      "id": "image_base",
      "label": "Imagen principal"
    },
    {
      "type": "image_picker",
      "id": "image_reveal",
      "label": "Imagen revelada (bajo el lente)"
    },
    {
      "type": "header",
      "content": "Lente"
    },
    {
      "type": "range",
      "id": "lens_size",
      "label": "Tamaño del lente (px)",
      "min": 80,
      "max": 500,
      "step": 10,
      "default": 200
    },
    {
      "type": "range",
      "id": "smoothing",
      "label": "Suavizado (1 directo · 12 fluido)",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Proporción",
      "options": [
        { "value": "16/9", "label": "16:9 Panorámica" },
        { "value": "4/3",  "label": "4:3 Clásica" },
        { "value": "1/1",  "label": "1:1 Cuadrada" },
        { "value": "3/2",  "label": "3:2 Fotografía" }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Ancho máximo (px)",
      "min": 600,
      "max": 1920,
      "step": 20,
      "default": 1400
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Etiqueta inferior",
      "placeholder": "Ej: Antes / Después"
    },
    {
      "type": "checkbox",
      "id": "hide_hint",
      "label": "Ocultar indicador de interacción",
      "default": false
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Texto del indicador",
      "default": "Pasa el cursor para revelar"
    }
  ],
  "presets": [
    {
      "name": "Image Reveal Lens",
      "category": "Image"
    }
  ]
}
{% endschema %}
