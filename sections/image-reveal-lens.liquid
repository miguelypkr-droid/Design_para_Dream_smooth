{% comment %}
  Section: Image Reveal Lens
  Efecto de lente circular que revela una segunda imagen al pasar el mouse o tocar en mobile.
  Configuración: imagen principal, imagen revelada, tamaño del lente, texto opcional.
{% endcomment %}

<style>
  #ir-section-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #0a0a0a;
    cursor: none;
  }

  #ir-section-{{ section.id }} .ir-wrapper {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    aspect-ratio: {{ section.settings.aspect_ratio }};
    overflow: hidden;
  }

  #ir-section-{{ section.id }} .ir-img-base,
  #ir-section-{{ section.id }} .ir-img-reveal {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  #ir-section-{{ section.id }} .ir-img-reveal {
    z-index: 2;
    opacity: 0;
    clip-path: circle(0px at -200px -200px);
    transition: clip-path 0.05s linear;
    will-change: clip-path;
  }

  #ir-section-{{ section.id }} .ir-img-base {
    z-index: 1;
  }

  #ir-section-{{ section.id }} .ir-cursor {
    position: absolute;
    z-index: 10;
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.25s ease;
    will-change: transform;
  }

  #ir-section-{{ section.id }} .ir-cursor-ring {
    width: {{ section.settings.lens_size }}px;
    height: {{ section.settings.lens_size }}px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.7);
    box-shadow:
      0 0 0 1px rgba(0,0,0,0.3),
      inset 0 0 0 1px rgba(0,0,0,0.2);
    backdrop-filter: blur(0px);
  }

  #ir-section-{{ section.id }} .ir-cursor-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
  }

  #ir-section-{{ section.id }} .ir-label {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    text-align: center;
    pointer-events: none;
  }

  #ir-section-{{ section.id }} .ir-label-text {
    display: inline-block;
    font-family: {{ section.settings.font_family }};
    font-size: clamp(0.75rem, 1.2vw, 0.875rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    background: rgba(0,0,0,0.3);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
  }

  #ir-section-{{ section.id }} .ir-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 15;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  #ir-section-{{ section.id }} .ir-hint-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.7);
    font-family: {{ section.settings.font_family }};
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  #ir-section-{{ section.id }} .ir-hint-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: ir-pulse-{{ section.id }} 2s ease-in-out infinite;
  }

  @keyframes ir-pulse-{{ section.id }} {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  @media (hover: none) {
    #ir-section-{{ section.id }} {
      cursor: default;
    }
    #ir-section-{{ section.id }} .ir-hint-text-desktop {
      display: none;
    }
  }

  @media (hover: hover) {
    #ir-section-{{ section.id }} .ir-hint-text-mobile {
      display: none;
    }
  }
</style>

<section
  id="ir-section-{{ section.id }}"
  class="ir-section"
  aria-label="{{ section.settings.aria_label | default: 'Galería con efecto de revelado' }}"
>
  <div class="ir-wrapper" id="ir-wrapper-{{ section.id }}">

    {% if section.settings.image_base != blank %}
      <img
        class="ir-img-base"
        src="{{ section.settings.image_base | image_url: width: 2000 }}"
        srcset="
          {{ section.settings.image_base | image_url: width: 600 }} 600w,
          {{ section.settings.image_base | image_url: width: 1200 }} 1200w,
          {{ section.settings.image_base | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ section.settings.image_base.alt | default: section.settings.image_base_alt }}"
        loading="eager"
        draggable="false"
      >
    {% else %}
      <div class="ir-img-base" style="background: #1a1a2e; display:flex; align-items:center; justify-content:center;">
        <span style="color:rgba(255,255,255,0.2); font-size:1rem; letter-spacing:0.1em;">IMAGEN PRINCIPAL</span>
      </div>
    {% endif %}

    {% if section.settings.image_reveal != blank %}
      <img
        class="ir-img-reveal"
        id="ir-reveal-{{ section.id }}"
        src="{{ section.settings.image_reveal | image_url: width: 2000 }}"
        srcset="
          {{ section.settings.image_reveal | image_url: width: 600 }} 600w,
          {{ section.settings.image_reveal | image_url: width: 1200 }} 1200w,
          {{ section.settings.image_reveal | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ section.settings.image_reveal.alt | default: section.settings.image_reveal_alt }}"
        loading="eager"
        draggable="false"
      >
    {% else %}
      <div
        class="ir-img-reveal"
        id="ir-reveal-{{ section.id }}"
        style="background: linear-gradient(135deg, #e94560 0%, #f5a623 100%); display:flex; align-items:center; justify-content:center;"
      >
        <span style="color:rgba(255,255,255,0.4); font-size:1rem; letter-spacing:0.1em;">IMAGEN REVELADA</span>
      </div>
    {% endif %}

    <div class="ir-cursor" id="ir-cursor-{{ section.id }}">
      <div class="ir-cursor-ring"></div>
      <div class="ir-cursor-dot"></div>
    </div>

    {% unless section.settings.hide_hint %}
      <div class="ir-hint" id="ir-hint-{{ section.id }}">
        <div class="ir-hint-inner">
          <div class="ir-hint-circle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4M12 16h.01"/>
            </svg>
          </div>
          <span class="ir-hint-text-desktop">
            {{ section.settings.hint_text_desktop | default: 'Pasa el cursor para revelar' }}
          </span>
          <span class="ir-hint-text-mobile">
            {{ section.settings.hint_text_mobile | default: 'Toca para revelar' }}
          </span>
        </div>
      </div>
    {% endunless %}

    {% if section.settings.label_text != blank %}
      <div class="ir-label">
        <span class="ir-label-text">{{ section.settings.label_text }}</span>
      </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var lensSize  = {{ section.settings.lens_size | default: 200 }};
  var smoothing = {{ section.settings.smoothing | default: 6 }};

  var wrapper  = document.getElementById('ir-wrapper-' + sectionId);
  var reveal   = document.getElementById('ir-reveal-' + sectionId);
  var cursor   = document.getElementById('ir-cursor-' + sectionId);
  var hint     = document.getElementById('ir-hint-' + sectionId);

  if (!wrapper || !reveal) return;

  var targetX = -lensSize * 2;
  var targetY = -lensSize * 2;
  var currentX = targetX;
  var currentY = targetY;
  var isActive = false;
  var rafId   = null;
  var halfLens = lensSize / 2;

  function setReveal(x, y) {
    reveal.style.clipPath = 'circle(' + halfLens + 'px at ' + Math.round(x) + 'px ' + Math.round(y) + 'px)';
    cursor.style.transform = 'translate(' + Math.round(x) + 'px,' + Math.round(y) + 'px) translate(-50%,-50%)';
  }

  function animate() {
    if (!isActive) { rafId = null; return; }
    var dx = targetX - currentX;
    var dy = targetY - currentY;
    currentX += dx / smoothing;
    currentY += dy / smoothing;
    setReveal(currentX, currentY);
    rafId = requestAnimationFrame(animate);
  }

  function getRelativePos(clientX, clientY) {
    var rect = wrapper.getBoundingClientRect();
    return {
      x: clientX - rect.left,
      y: clientY - rect.top
    };
  }

  function enter() {
    isActive = true;
    reveal.style.opacity = '1';
    cursor.style.opacity = '1';
    if (hint) hint.style.opacity = '0';
    if (!rafId) rafId = requestAnimationFrame(animate);
  }

  function leave() {
    isActive = false;
    reveal.style.opacity = '0';
    cursor.style.opacity = '0';
    if (hint) hint.style.opacity = '1';
    reveal.style.clipPath = 'circle(0px at ' + Math.round(currentX) + 'px ' + Math.round(currentY) + 'px)';
    targetX = -lensSize * 2;
    targetY = -lensSize * 2;
    currentX = targetX;
    currentY = targetY;
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  function move(clientX, clientY) {
    var pos = getRelativePos(clientX, clientY);
    targetX = pos.x;
    targetY = pos.y;
  }

  wrapper.addEventListener('mouseenter', function(e) {
    enter();
    move(e.clientX, e.clientY);
  });

  wrapper.addEventListener('mousemove', function(e) {
    move(e.clientX, e.clientY);
  });

  wrapper.addEventListener('mouseleave', function() {
    leave();
  });

  wrapper.addEventListener('touchstart', function(e) {
    if (e.touches.length > 0) {
      enter();
      move(e.touches[0].clientX, e.touches[0].clientY);
    }
  }, { passive: true });

  wrapper.addEventListener('touchmove', function(e) {
    e.preventDefault();
    if (e.touches.length > 0) {
      move(e.touches[0].clientX, e.touches[0].clientY);
    }
  }, { passive: false });

  wrapper.addEventListener('touchend', function() {
    leave();
  });

  wrapper.addEventListener('touchcancel', function() {
    leave();
  });
})();
</script>

{% schema %}
{
  "name": "Image Reveal Lens",
  "tag": "section",
  "class": "ir-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Imágenes"
    },
    {
      "type": "image_picker",
      "id": "image_base",
      "label": "Imagen principal (visible por defecto)"
    },
    {
      "type": "text",
      "id": "image_base_alt",
      "label": "Texto alternativo — imagen principal",
      "default": "Imagen principal"
    },
    {
      "type": "image_picker",
      "id": "image_reveal",
      "label": "Imagen revelada (aparece bajo el lente)"
    },
    {
      "type": "text",
      "id": "image_reveal_alt",
      "label": "Texto alternativo — imagen revelada",
      "default": "Imagen revelada"
    },
    {
      "type": "header",
      "content": "Lente y animación"
    },
    {
      "type": "range",
      "id": "lens_size",
      "label": "Tamaño del lente (px)",
      "min": 80,
      "max": 500,
      "step": 10,
      "default": 200
    },
    {
      "type": "range",
      "id": "smoothing",
      "label": "Suavizado del movimiento (1 = directo, 12 = lento)",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Proporción de la imagen",
      "options": [
        { "value": "16/9",  "label": "Panorámica 16:9" },
        { "value": "4/3",   "label": "Clásica 4:3" },
        { "value": "1/1",   "label": "Cuadrada 1:1" },
        { "value": "3/2",   "label": "Fotografía 3:2" },
        { "value": "21/9",  "label": "Ultra-wide 21:9" }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Ancho máximo del contenedor (px)",
      "min": 600,
      "max": 1920,
      "step": 20,
      "default": 1400
    },
    {
      "type": "header",
      "content": "Texto y accesibilidad"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Etiqueta inferior (opcional)",
      "placeholder": "Ej: Antes / Después"
    },
    {
      "type": "checkbox",
      "id": "hide_hint",
      "label": "Ocultar indicador de interacción",
      "default": false
    },
    {
      "type": "text",
      "id": "hint_text_desktop",
      "label": "Texto del indicador — desktop",
      "default": "Pasa el cursor para revelar"
    },
    {
      "type": "text",
      "id": "hint_text_mobile",
      "label": "Texto del indicador — mobile",
      "default": "Toca para revelar"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Etiqueta de accesibilidad (aria-label)",
      "default": "Galería con efecto de revelado"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Tipografía del texto",
      "options": [
        { "value": "var(--font-body-family, sans-serif)", "label": "Fuente del tema" },
        { "value": "sans-serif",  "label": "Sans-serif genérica" },
        { "value": "serif",       "label": "Serif genérica" },
        { "value": "monospace",   "label": "Monospace" }
      ],
      "default": "var(--font-body-family, sans-serif)"
    }
  ],
  "presets": [
    {
      "name": "Image Reveal Lens",
      "category": "Image"
    }
  ]
}
{% endschema %}
