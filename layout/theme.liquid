<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    <style>
      .page-curtains {
        position: fixed;
        inset: 0;
        z-index: 999999;
        display: flex;
        pointer-events: none;
      }
      .page-curtains.curtains-done {
        display: none;
      }
      .curtain-panel {
        width: 50%;
        height: 100%;
        background: #000;
        display: flex;
        align-items: center;
        transition: transform 1.1s cubic-bezier(0.77, 0, 0.18, 1);
      }
      .curtain-panel--left {
        justify-content: flex-end;
      }
      .curtain-panel--right {
        justify-content: flex-start;
      }
      .curtain-logo {
        width: 160px;
        height: auto;
        display: block;
        opacity: 1;
        transition: opacity 0.3s ease;
        user-select: none;
        pointer-events: none;
      }
      .curtain-panel--right .curtain-logo {
        opacity: 0;
      }
      .page-curtains.curtains-open .curtain-panel--left {
        transform: translateX(-100%);
      }
      .page-curtains.curtains-open .curtain-panel--right {
        transform: translateX(100%);
      }
      .page-curtains.curtains-open .curtain-logo {
        opacity: 0;
      }
    </style>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }},
      "logo": "https://dreamsmoothh.com/cdn/shop/files/LOGO_DREAM_SMOOTH.png?v=1780287234&width=320",
      "sameAs": [
        {% if settings.social_instagram_link != blank %}{{ settings.social_instagram_link | json }}{% endif %}
      ]
    }
    </script>

    {%- if request.page_type == 'product' -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 200 | json }},
      "image": {{ product.featured_image | image_url: width: 800 | prepend: 'https:' | json }},
      "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ product.price | money_without_currency | strip_html | json }},
        "availability": {% if product.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},
        "url": {{ canonical_url | json }}
      }
    }
    </script>
    {%- endif -%}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">

    <div class="page-curtains" id="pageCurtains" aria-hidden="true">
      <div class="curtain-panel curtain-panel--left">
        <img class="curtain-logo" src="https://dreamsmoothh.com/cdn/shop/files/LOGO_DREAM_SMOOTH.png?v=1780287234&width=320" alt="Dream Smooth" width="160" height="auto" fetchpriority="high">
      </div>
      <div class="curtain-panel curtain-panel--right">
        <img class="curtain-logo" src="https://dreamsmoothh.com/cdn/shop/files/LOGO_DREAM_SMOOTH.png?v=1780287234&width=320" alt="Dream Smooth" width="160" height="auto">
      </div>
    </div>

    <script>
      (function () {
        var curtains = document.getElementById('pageCurtains');
        if (!curtains) return;
        // Pequeña pausa para que el navegador pinte las cortinas antes de abrirlas
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            setTimeout(function () {
              curtains.classList.add('curtains-open');
              curtains.addEventListener('transitionend', function handler(e) {
                if (e.target === curtains.querySelector('.curtain-panel--right')) {
                  curtains.classList.add('curtains-done');
                  curtains.removeEventListener('transitionend', handler);
                }
              });
            }, 350);
          });
        });
      })();
    </script>
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <!-- Background music -->
    <audio id="ds-bg-audio" loop preload="metadata">
      <source src="https://cdn.shopify.com/s/files/1/0770/0751/9995/files/twentythree_-_Queen_St_Lyrics.mp3?v=1780322119" type="audio/mpeg">
    </audio>

    <button id="ds-audio-btn" aria-label="Activar música" title="Activar música">
      <svg id="ds-icon-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
        <path d="M3.63 3.63a1 1 0 0 0 0 1.41L7.29 8.7 7 9H4a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h3l3.29 3.29c.63.63 1.71.18 1.71-.71v-4.17l4.18 4.18A7 7 0 0 1 5.19 9.1L3.63 7.54a1 1 0 0 0-1.42 1.42l.42.42A9 9 0 0 0 13 20.93V21c0 .55.45 1 1 1s1-.45 1-1v-.08a9 9 0 0 0 4.95-2.6l1.42 1.43a1 1 0 1 0 1.41-1.41L5.04 3.63a1 1 0 0 0-1.41 0zM11 15.17l-1.88-1.88L11 12v3.17zm7.22-1.77A5 5 0 0 0 19 12v-1a1 1 0 0 0-2 0v1a3 3 0 0 1-.22 1.12l1.44 1.28zM14 3c-.55 0-1 .45-1 1v.18l2 2V4a1 1 0 0 0-1-1zm3 6.17V8a3 3 0 0 0-3-3 3 3 0 0 0-.8.11L15.07 7A1 1 0 0 1 17 8v1.17z"/>
      </svg>
      <svg id="ds-icon-playing" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="display:none">
        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
      </svg>
    </button>

    <style>
      #ds-audio-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: none;
        background: rgba(0,0,0,0.75);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(0,0,0,0.4);
        backdrop-filter: blur(6px);
        transition: transform 0.15s, background 0.2s;
      }
      #ds-audio-btn:hover {
        transform: scale(1.1);
        background: rgba(0,0,0,0.9);
      }
    </style>

    <script>
    (function () {
      var audio    = document.getElementById('ds-bg-audio');
      var btn      = document.getElementById('ds-audio-btn');
      var iMuted   = document.getElementById('ds-icon-muted');
      var iPlaying = document.getElementById('ds-icon-playing');

      audio.volume = 0.5;

      function setUI(isPlaying) {
        iMuted.style.display   = isPlaying ? 'none' : '';
        iPlaying.style.display = isPlaying ? '' : 'none';
        btn.setAttribute('aria-label', isPlaying ? 'Silenciar música' : 'Activar música');
        btn.setAttribute('title',      isPlaying ? 'Silenciar música' : 'Activar música');
      }

      // Sincronizar UI con eventos reales del audio
      audio.addEventListener('play',  function() { setUI(true);  });
      audio.addEventListener('pause', function() { setUI(false); });
      audio.addEventListener('ended', function() { setUI(false); });

      btn.addEventListener('click', function () {
        if (audio.paused) {
          audio.play().catch(function() { setUI(false); });
        } else {
          audio.pause();
        }
      });

      // Autoplay muted al cargar (Chrome lo permite; si no, queda listo para el botón)
      window.addEventListener('load', function () {
        audio.muted = true;
        audio.play().then(function () {
          audio.muted = false;
        }).catch(function () {
          audio.muted = false;
        });
      });
    })();
    </script>

  </body>
</html>
